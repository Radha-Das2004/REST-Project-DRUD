<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> View Separate Post</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
     <h2>Hera is Your post in detail</h2>
     <p>Post Id : <%= post.id %></p>
     <div class="post">
        <h3 class="user"><%= post.username %></h3>
        <p class="content"><%= post.content %></p>
        <a class="btn-index" href="/posts">Back</a>
     </div>
</body>
</html>