<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Posts</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
     <h1>Quora Posts</h1>
     <% for(post of posts) { %>
        <div class="post">
            <h2 class="user"><%= post.username %></h2>
            <p class="content"><%= post.content %></p>
            <a  class="btn-index" href="/posts/<%= post.id %>">View Post</a>
            <a  class="btn-index" href="/posts/<%= post.id %>/edit">Edit Content</a>
            <form method="post" action="/posts/<%= post.id %>?_method=DELETE">
                <button class="delete-btn" >Delete Post</button>
            </form>
        </div>
     <% } %>

     <br />
     <br />
     <a class="btn-index btn1" href="http://localhost:3000/posts/new">Create New Post</a>
</body>
</html>