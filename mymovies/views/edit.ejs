<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MOVIES EDITs</title>
    <link rel="stylesheet" href="/index.css">
</head> 
</head>
<body>
     <div class="container2">
        <div class="container1">
            <h1 class="h1">Movies Details</h1>
                <div class="movie">
                    <span class="span-movie-image"><img src="<%= movie.image %>" class="movie-image" alt="<%= movie.title %>"></span>
                    <h2 class="h2-title"><%= movie.title %></h2>
                    <div class="movie-info1">
                        <span> <p class="p-genre">Genre: <%= movie.genre %></p></span>
                        <span> <p class="p-genre">Rating: <%= movie.rating %></p></span>
                    </div>
                    <span> <a href="http://localhost:3000/movies" class="add-movie-link">Back to Movies List</a></span>
                    
                </div>
        </div>
        <div class="container1">
            <h1 class="h1-new">Update Movie</h1>
        
            <form action="/movies/<%= movie.id %>?_method=PATCH" method="POST" class="movie-form">
            <div class="form-container">
                    <span ><label for="title">Title:</label>
                    <input type="text" id="title" class="from-input"
                     name="title" placeholder="<%= movie.title %>"  value="<%= movie.title %>" >
                     </span>

                <span><label for="genre">Genre:</label>
                    <input type="text" id="genre" class="from-input" name="genre" placeholder="<%= movie.genre %>"  value="<%= movie.genre %>"></span>

                    <span><label for="rating">Rating:</label>
                    <input type="number" id="rating" class="from-input" name="rating" min="0" max="10" step="0.1" placeholder="<%= movie.rating %>"  value="<%= movie.rating %>"></span>

                    <span><label for="image">Image URL:</label>
                    <input type="text" id="image" class="from-input" placeholder="<%= movie.image %>" name="image" value="<%= movie.image %>"></span>

                            <button type="submit" class="add-movie-link">Update Movie</button>
                    </div>
                </form>
        </div>
    </div>

    
</body>
</html>