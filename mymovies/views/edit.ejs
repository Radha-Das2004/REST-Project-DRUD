<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Movie - <%= movie.title %></title>
    <link rel="stylesheet" href="/index.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head> 
<body>
    <div class="overlay"></div>

    <div class="container2">
        <div class="container1 movie-preview-card">
            <h1 class="h1">Movie Details</h1>
            <div class="movie">
                <div class="span-movie-image">
                    <img src="<%= movie.image %>" class="movie-image" alt="<%= movie.title %>">
                </div>
                <h2 class="h2-title"><%= movie.title %></h2>
                
                <div class="movie-info1">
                    <span class="badge-info">Genre: <%= movie.genre %></span>
                    <span class="badge-info">Rating: ⭐ <%= movie.rating %></span>
                </div>
                
                <div class="span-password">
                    <p class="db-password-text">Current Key: <span><%= movie.password %></span></p>
                    <a href="/movies" class="btn-secondary">← Back to List</a>
                </div>
            </div>
        </div>

        <div class="container1 edit-form-card">
            <h1 class="h1-new">Update Movie</h1>
        
            <form action="/movies/<%= movie.id %>?_method=PATCH" method="POST" class="movie-form">
                <div class="form-container">
                    <div class="form-group">
                        <label for="title">Title:</label>
                        <input type="text" id="title" class="from-input" name="title" placeholder="<%= movie.title %>" value="<%= movie.title %>">
                    </div>

                    <div class="form-group">
                        <label for="genre">Genre:</label>
                        <input type="text" id="genre" class="from-input" name="genre" placeholder="<%= movie.genre %>" value="<%= movie.genre %>">
                    </div>

                    <div class="form-group">
                        <label for="rating">Rating:</label>
                        <input type="number" id="rating" class="from-input" name="rating" min="0" max="10" step="0.1" placeholder="<%= movie.rating %>" value="<%= movie.rating %>">
                    </div>

                    <div class="form-group">
                        <label for="image">Image URL:</label>
                        <input type="text" id="image" class="from-input" placeholder="<%= movie.image %>" name="image" value="<%= movie.image %>">
                    </div>

                    <div class="form-group highlight-group">
                        <label for="password">Confirm Password to Save:</label>
                        <input type="password" id="password" class="from-input" name="password" placeholder="Enter password to verify" required>
                    </div>

                    <button type="submit" class="add-movie-link">Update Details</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>