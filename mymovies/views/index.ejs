<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie Tracker - Collection</title>
    <link rel="stylesheet" href="/index.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="overlay"></div>

    <div class="main-wrapper">
        <header class="movies-header">
            <h1 class="h1">Movie Tracker</h1>
            <a href="/movies/new" class="btn-add-new">+ Add New Movie</a>
        </header>
        
        <div class="movies-grid">
            <% for( let movie of movies ) { %>
                <div class="movie-card">
                    <div class="span-movie-image">
                        <img src="<%= movie.image %>" class="movie-image" alt="<%= movie.title %>">
                    </div>
                    
                    <div class="movie-card-body">
                        <h2 class="h2-title"><%= movie.title %></h2>
                        
                        <div class="movie-info">
                            <span class="genre-tag"><%= movie.genre %></span>
                            <span class="rating-tag">⭐ <%= movie.rating %></span>
                        </div>
                        
                        <div class="movie-actions">
                            <a href="/movies/<%= movie.id %>" class="action-btn btn-view">View</a>
                            <a href="/movies/<%= movie.id %>/edit" class="action-btn btn-edit">Edit</a>
                        </div> 
                        
                        <div class="movie-info3">
                            <form action="/movies/<%= movie.id %>/delete" method="get">
                                <button type="submit" class="action-btn btn-delete">Delete Movie</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>