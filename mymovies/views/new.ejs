<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEW Movies Add</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <div class="container">
        <h1 class="h1-new">Add a New Movie</h1>
        
            <form action="/movies" method="POST" class="movie-form">
            <div class="form-container">
                    <span ><label for="title">Title:</label>
                    <input type="text" id="title" class="from-input"
                     name="title" required></span>

                <span><label for="genre">Genre:</label>
                    <input type="text" id="genre" class="from-input" name="genre" required></span>

                    <span><label for="rating">Rating:</label>
                    <input type="number" id="rating" class="from-input" name="rating" min="0" max="10" step="0.1" required></span>

                    <span><label for="image">Image URL:</label>
                    <input type="text" id="image" class="from-input" name="image"></span>

                    <button type="submit" class="add-movie-link">Add Movie</button>
             </div>
        </form>
       
    </div>
    
</body>
</html>