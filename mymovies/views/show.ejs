<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ID</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <div class="container">
        <h1 class="h1">Movies Details</h1>
        <div class="movie">
            <span class="span-movie-image"><img src="<%= movie.image %>" class="movie-image" alt="<%= movie.title %>"></span>
            <h2 class="h2-title"><%= movie.title %></h2>
            <div class="movie-info1">
                 <span> <p class="p-genre">Genre: <%= movie.genre %></p></span>
                 <span> <p class="p-genre">Rating: <%= movie.rating %></p></span>
            </div>
            <span> <a href="http://localhost:3000/movies" class="add-movie-link">Back to Movies List</a></span>
            
        </div>
    </div>
</body>
</html>