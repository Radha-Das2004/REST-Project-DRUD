<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie Tracker - Dashboard</title>
    <link rel="stylesheet" href="/publics.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="overlay"></div>
    
    <div class="dashboard-container">
        <header class="main-header">
            <h1>Movie Tracker</h1>
        </header>

        <main class="stats-card">
            <div class="stats-icon">🎬</div>
            <h2>Total Movies Tracked</h2>
            <div class="counter-badge"><%= count %></div>
            <p>Explore, edit, and manage your personalized anime and movie database collection instantly.</p>
            
            <a href="/movies" class="btn-primary">View Collection</a>
        </main>
    </div>
</body>
</html>