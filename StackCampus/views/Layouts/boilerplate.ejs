<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'StackCampus' %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <header class="sc-header">
        <nav class="sc-navbar">
            <a href="/stackcampus" class="sc-logo">
                <span class="material-symbols-outlined school-icon">school</span> 
                <span class="logo-text">Stack<span>Campus</span></span>
            </a>

            <div class="sc-nav-actions">
                <button type="button" id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle Theme">
                    <span class="material-symbols-outlined light-icon">light_mode</span>
                    <span class="material-symbols-outlined dark-icon">dark_mode</span>
                </button>

                <% if (typeof currentUser !== 'undefined' && currentUser) { %>
                    <div class="sc-user-session">
                        <div class="sc-profile-badge">
                            <span class="role-tag"><%= currentUser.role %></span>
                            <span class="user-name"><%= currentUser.name %></span>
                        </div>
                        <form method="get" action="/stackcampus/logout" class="inline-form">
                            <button type="submit" class="sc-btn sc-btn-secondary">Logout</button>
                        </form>
                    </div>
                <% } else { %>
                    <div class="sc-auth-actions">
                        <form method="get" action="/stackcampus/login" class="inline-form">
                            <button type="submit" class="sc-btn sc-btn-ghost">Login</button>
                        </form>
                        <form method="get" action="/stackcampus/register" class="inline-form">
                            <button type="submit" class="sc-btn sc-btn-ghost">Register</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </nav>
    </header>

    <main class="sc-main-container">
        <%- body %>
    </main>

    <script>
        const themeToggleBtn = document.getElementById('theme-toggle');
        const currentTheme = localStorage.getItem('theme') || 'dark';

        // Set initial state
        document.documentElement.setAttribute('data-theme', currentTheme);

        themeToggleBtn.addEventListener('click', () => {
            let activeTheme = document.documentElement.getAttribute('data-theme');
            let newTheme = activeTheme === 'dark' ? 'light' : 'dark';
            
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
        });
    </script>
</body>
</html>