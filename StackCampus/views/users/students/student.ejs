<% layout("/layouts/boilerplate") %>

<div class="sc-student-wrapper">
    <header class="sc-dashboard-header">
        <div class="header-left">
            <div class="sc-student-profile-zone">
                <div class="sc-profile-avatar-container">
                    <img src="<%= (typeof student !== 'undefined' && student.image) ? student.image : '/default.png' %>" alt="Student Profile" class="sc-student-avatar" onerror="this.src='/default.png'">
                    <span class="sc-online-status"></span>
                </div>
                <div>
                    <h2>Student Dashboard</h2>
                    <p>Welcome back, Student <strong><%= student.name %></strong></p>
                </div>
            </div>
        </div>
    </header>

    <section class="sc-portal-gateway-deck">
        <a href="/stackcampus/student/available" class="sc-gateway-card card-primary">
            <div class="sc-gateway-content">
                <div class="sc-gateway-icon-box">
                    <span class="material-symbols-outlined">explore</span>
                </div>
                <div class="sc-gateway-text">
                    <h3>Available Batches</h3>
                    <p>Explore elite computing paths and join active live tracks.</p>
                </div>
            </div>
            <span class="sc-gateway-arrow material-symbols-outlined">arrow_forward</span>
        </a>

        <a href="/stackcampus/student/mybatches" class="sc-gateway-card card-success">
            <div class="sc-gateway-content">
                <div class="sc-gateway-icon-box">
                    <span class="material-symbols-outlined">menu_book</span>
                </div>
                <div class="sc-gateway-text">
                    <h3>My Batches</h3>
                    <p>Access your currently allocated curriculums and learning resources.</p>
                </div>
            </div>
            <span class="sc-gateway-arrow material-symbols-outlined">arrow_forward</span>
        </a>
    </section>
</div>