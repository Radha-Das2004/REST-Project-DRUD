<% layout("/layouts/boilerplate") %>

<div class="sc-dashboard-wrapper">
    <header class="sc-dashboard-header">
        <div class="header-left">
            <span class="material-symbols-outlined dashboard-icon text-green-glow">task_alt</span>
            <div>
                <h2>My Active Curriculums</h2>
                <p>Track your enrolled academic programs, course schedules, and allocated labs.</p>
            </div>
        </div>
        <div class="header-right">
            <a href="/stackcampus/student" class="sc-action-pill">
                <span class="material-symbols-outlined">arrow_back</span>
                <span>Back to Dashboard</span>
            </a>
        </div>
    </header>

    <section class="sc-courses-matrix">
        <% if (enrolledBatches.length === 0) { %>
            <div class="sc-empty-matrix-fallback warning-state">
                <span class="material-symbols-outlined fallback-icon">assignment_late</span>
                <h3>No Active Enrollments</h3>
                <p>Your learning itinerary is currently clear. Head over to the course tracks page to view available open configurations.</p>
                <a href="/stackcampus/student/available" class="sc-btn sc-btn-primary sc-empty-action-btn">
                    <span class="material-symbols-outlined">search</span> Explore Available Batches
                </a>
            </div>
        <% } else { %>
            <div class="sc-cards-grid">
                <% for(let batch of enrolledBatches) { %>
                    <div class="sc-course-card enrolled-border-accent">
                        <div class="sc-card-media-wrapper">
                            <img src="<%= batch.batchImage || 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=600' %>" alt="<%= batch.batchName %> Image" class="sc-card-img" onerror="this.src='https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=600'">
                            <div class="sc-media-gradient-overlay"></div>
                            
                            <div class="sc-floating-verification-tag">
                                <span class="material-symbols-outlined verification-checkmark">verified</span>
                                <span>Active Student</span>
                            </div>
                        </div>

                        <div class="sc-card-body-content">
                            <h4 class="sc-card-title-text"><%= batch.batchName %></h4>
                            
                            <div class="sc-instructor-profile-row">
                                <span class="material-symbols-outlined field-icon">account_box</span>
                                <div class="instructor-meta">
                                    <span class="meta-label">Lead Faculty</span>
                                    <span class="meta-value"><%= batch.teacher ? batch.teacher.name : 'Staff Instructor' %></span>
                                </div>
                            </div>
                        </div>

                        <div class="sc-card-footer-actions sc-enrolled-actions-block">
                            <div class="sc-status-indicator-bar">
                                <span class="material-symbols-outlined">check_circle</span>
                                <span>Successfully Registered</span>
                            </div>

                            <form method="POST" action="/stackcampus/student/<%= student._id %>/unenroll" class="sc-enrollment-form">
                                <input type="hidden" name="batchId" value="<%= batch._id %>">
                                <button type="submit" class="sc-btn sc-btn-danger-action" 
                                        onclick="return confirm('क्या आप सच में इस बैच को छोड़ना चाहते हैं?')">
                                    <span class="material-symbols-outlined">disabled_by_default</span>
                                    <span>Unenroll / Drop Class</span>
                                </button>
                            </form>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>
    </section>
</div>