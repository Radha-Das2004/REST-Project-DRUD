<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedIntimate — Add New Staff</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --teal-800: #0a4a43; --teal-700: #0f6b60; --teal-500: #1cab97;
            --teal-400: #3fc9b4; --mint-300: #8fe9d6;
            --bg-deep: #071a1d;
            --surface: rgba(255,255,255,0.045);
            --border-soft: rgba(143,233,214,0.16);
            --text-primary: #eafffa; --text-muted: #9fc7c0;
            --ok: #4ee2a4; --danger: #ff6b6b;
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0; padding: 0; min-height: 100vh;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-primary);
            background-color: var(--bg-deep);
        }

        body {
            background-image:
                linear-gradient(180deg, rgba(4,18,20,0.92) 0%, rgba(4,24,24,0.95) 45%, rgba(2,12,13,0.98) 100%),
                url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed; inset: 0;
            background:
                radial-gradient(900px 500px at 12% -5%, rgba(28,171,151,0.20), transparent 60%),
                radial-gradient(700px 500px at 110% 10%, rgba(63,201,180,0.14), transparent 60%);
            pointer-events: none; z-index: 0;
        }

        .shell {
            position: relative; z-index: 1;
            max-width: 600px;
            margin: 0 auto;
            padding: 38px 28px 80px;
        }

        /* ── Top Nav Bar ── */
        .top-utility-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            animation: slideDown 0.65s cubic-bezier(.16,1,.3,1) both;
        }

        .btn-utility-nav {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 9px 15px; border-radius: 11px; text-decoration: none;
            font-size: 0.83rem; font-weight: 700; color: var(--text-muted);
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border-soft);
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
        }
        .btn-utility-nav i { transition: transform 0.28s ease; }
        .btn-utility-nav:first-child:hover i { transform: translateX(-3px); }
        .btn-utility-nav:last-child:hover i { transform: scale(1.1); }
        .btn-utility-nav:hover {
            color: var(--text-primary); background: rgba(255,255,255,0.09);
            border-color: var(--teal-500); transform: translateY(-2px);
        }

        /* ── Form Card ── */
        .premium-form-card {
            background: linear-gradient(160deg, rgba(255,255,255,0.065), rgba(255,255,255,0.02));
            border: 1px solid var(--border-soft);
            border-radius: 24px; padding: 36px;
            position: relative; overflow: hidden;
            box-shadow: 0 0 0 1px rgba(143,233,214,0.08), 0 20px 60px -20px rgba(0,0,0,0.6);
            animation: cardIn 0.7s cubic-bezier(.16,1,.3,1) 0.1s both;
        }

        /* Static gradient border */
        .premium-form-card::after {
            content: "";
            position: absolute; inset: -1px; border-radius: 24px; padding: 1px;
            background: linear-gradient(135deg, rgba(63,201,180,0), rgba(63,201,180,0.4), rgba(63,201,180,0));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask-composite: exclude;
            opacity: 0.6; pointer-events: none;
        }

        /* Shimmer sweep */
        .premium-form-card .shimmer {
            position: absolute; inset: 0;
            background: linear-gradient(105deg, transparent 40%, rgba(143,233,214,0.06) 50%, transparent 60%);
            transform: translateX(-100%);
            border-radius: 24px; pointer-events: none;
            animation: shimmer 4s ease 1s infinite;
        }

        /* ── Form Header ── */
        .form-header-block {
            margin-bottom: 28px; padding-bottom: 20px;
            border-bottom: 1px solid rgba(143,233,214,0.1);
        }

        .eyebrow {
            display: inline-flex; align-items: center; gap: 7px;
            font-size: 0.68rem; letter-spacing: 0.13em;
            text-transform: uppercase; color: var(--mint-300);
            font-weight: 700; margin-bottom: 8px;
        }

        .form-header-block h2 {
            font-family: 'Sora', sans-serif;
            font-size: 1.5rem; font-weight: 800;
            background: linear-gradient(95deg, #ffffff 10%, var(--mint-300) 90%);
            -webkit-background-clip: text; background-clip: text; color: transparent;
            margin: 0 0 6px; display: flex; align-items: center; gap: 10px;
        }
        .form-header-block h2 i { color: var(--teal-400); font-size: 1.2rem; }
        .form-header-block p { color: var(--text-muted); font-size: 0.84rem; margin: 0; line-height: 1.6; }

        /* ── Floating Label Fields ── */
        .interactive-input-group {
            position: relative; margin-bottom: 1.8rem;
        }

        .input-shell { position: relative; display: flex; align-items: center; }

        .input-shell .field-icon {
            position: absolute; left: 1.1rem; z-index: 2;
            color: rgba(143,233,214,0.3); font-size: 0.95rem;
            pointer-events: none;
            transition: color 0.25s ease, transform 0.25s ease;
        }

        .form-control-input {
            width: 100%;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border-soft);
            border-radius: 13px;
            padding: 1.1rem 1rem 1.1rem 3rem;
            color: var(--text-primary);
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.92rem; outline: none;
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
        }
        .form-control-input::placeholder { color: transparent; }

        .form-control-input:focus {
            background: rgba(255,255,255,0.07);
            border-color: var(--teal-500);
            box-shadow: 0 0 0 4px rgba(28,171,151,0.18);
        }
        .form-control-input:not(:placeholder-shown):valid {
            border-color: rgba(78,226,164,0.45);
            background: rgba(78,226,164,0.04);
        }
        .form-control-input:not(:placeholder-shown):invalid {
            border-color: rgba(255,107,107,0.45);
            background: rgba(255,107,107,0.04);
        }

        /* Floating label movement */
        .floating-label {
            position: absolute; left: 3rem; top: 50%;
            transform: translateY(-50%);
            color: rgba(143,233,214,0.45); font-size: 0.9rem;
            pointer-events: none;
            transition: all 0.25s cubic-bezier(.16,1,.3,1); z-index: 2;
        }

        .form-control-input:focus ~ .floating-label,
        .form-control-input:not(:placeholder-shown) ~ .floating-label {
            top: -0.45rem; left: 0.85rem;
            transform: translateY(0) scale(0.8);
            background: #071a1d; padding: 0 6px;
            color: var(--teal-500); font-weight: 700;
        }
        .form-control-input:not(:placeholder-shown):valid ~ .floating-label { color: var(--ok); }
        .form-control-input:not(:placeholder-shown):invalid ~ .floating-label { color: var(--danger); }

        /* Icon color changes with field state */
        .form-control-input:focus ~ .field-icon { color: var(--teal-400); transform: scale(1.1); }
        .form-control-input:not(:placeholder-shown):valid ~ .field-icon { color: var(--ok); }
        .form-control-input:not(:placeholder-shown):invalid ~ .field-icon { color: var(--danger); }

        /* ── Submit Button ── */
        .btn-registry-submit {
            width: 100%; margin-top: 6px;
            background: linear-gradient(135deg, var(--teal-500), var(--teal-700));
            color: #06231f; border: none; border-radius: 13px;
            padding: 1rem; cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            font-size: 0.97rem; font-weight: 700;
            display: inline-flex; align-items: center; justify-content: center; gap: 9px;
            box-shadow: 0 10px 28px -8px rgba(28,171,151,0.55);
            transition: all 0.3s cubic-bezier(.4,0,.2,1);
            position: relative; overflow: hidden;
        }
        .btn-registry-submit::before {
            content: "";
            position: absolute; inset: 0;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.22), transparent);
            transform: translateX(-120%); transition: transform 0.55s ease;
        }
        .btn-registry-submit:hover::before { transform: translateX(120%); }
        .btn-registry-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 36px -8px rgba(28,171,151,0.72);
        }
        .btn-registry-submit:active { transform: scale(0.98); }
        .btn-registry-submit i { transition: transform 0.3s cubic-bezier(.34,1.56,.64,1); }
        .btn-registry-submit:hover i { transform: rotate(20deg) scale(1.15); }

        /* ── Field stagger animations ── */
        .interactive-input-group:nth-child(1) { animation: fieldIn 0.5s ease 0.3s both; }
        .interactive-input-group:nth-child(2) { animation: fieldIn 0.5s ease 0.4s both; }
        .interactive-input-group:nth-child(3) { animation: fieldIn 0.5s ease 0.5s both; }
        .interactive-input-group:nth-child(4) { animation: fieldIn 0.5s ease 0.6s both; }
        .btn-registry-submit         { animation: fieldIn 0.5s ease 0.7s both; }

        /* ── Keyframes ── */
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-14px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(24px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes fieldIn {
            from { opacity: 0; transform: translateX(-12px); }
            to   { opacity: 1; transform: translateX(0); }
        }
        @keyframes shimmer {
            0%        { transform: translateX(-100%); }
            50%, 100% { transform: translateX(100%); }
        }
    </style>
</head>
<body>
    <div class="shell">

        <header class="top-utility-bar">
            <a href="/medIntimate/staffs" class="btn-utility-nav">
                <i class="fa-solid fa-arrow-left-long"></i> Directory
            </a>
            <a href="/medIntimate" class="btn-utility-nav">
                <i class="fa-solid fa-chart-pie"></i> Dashboard
            </a>
        </header>

        <main class="premium-form-card">
            <div class="shimmer"></div>

            <header class="form-header-block">
                <div class="eyebrow"><i class="fa-solid fa-heart-pulse"></i> MedIntimate · Staff Registry</div>
                <h2><i class="fa-solid fa-shield-heart"></i> Practitioner Registry</h2>
                <p>Onboard and authorize staff credentials to sync securely with the live patient allocation engine.</p>
            </header>

            <form method="POST" action="/medIntimate/staffs">

                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="text" id="name" name="staffName"
                               class="form-control-input" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-user-doctor field-icon"></i>
                        <label for="name" class="floating-label">Staff full name</label>
                    </div>
                </div>

                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="text" id="desg" name="designation"
                               class="form-control-input" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-stethoscope field-icon"></i>
                        <label for="desg" class="floating-label">Designation / role title</label>
                    </div>
                </div>

                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="text" id="ph" name="phone" pattern="[0-9]{10,}"
                               class="form-control-input" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-phone field-icon"></i>
                        <label for="ph" class="floating-label">Contact phone number</label>
                    </div>
                </div>

                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="url" id="img" name="image"
                               class="form-control-input" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-cloud-arrow-up field-icon"></i>
                        <label for="img" class="floating-label">Profile image URL</label>
                    </div>
                </div>

                <button type="submit" class="btn-registry-submit">
                    <span>Commit record &amp; authorize</span>
                    <i class="fa-solid fa-fingerprint"></i>
                </button>

            </form>
        </main>

    </div>
</body>
</html>