<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedIntimate — Secure Credential Modification</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="/style.css">
    
    <style>
        .form-page-wrapper {
            width: 100%;
            max-width: 640px;
            margin: 3rem auto;
            padding: 0 1.5rem;
            animation: consoleEntrance 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Top Utility Bar Navigation Actions */
        .top-utility-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.75rem;
        }

        .btn-utility-nav {
            color: #ffffff;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            padding: 0.75rem 1.25rem;
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            transition: var(--transition-smooth);
        }

        .btn-utility-nav:hover {
            background: rgba(30, 41, 59, 0.7);
            border-color: #0ea5e9;
            box-shadow: 0 0 15px rgba(14, 165, 233, 0.15);
            /* Physics wiggle trigger on nav hover */
            animation: macroWiggle 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
        }

        /* Premium Console Box Card Architecture */
        .premium-form-card {
            background: linear-gradient(145deg, rgba(15, 23, 42, 0.88) 0%, rgba(17, 24, 39, 0.78) 100%);
            border: 1px solid rgba(255, 255, 255, 0.09);
            border-radius: 28px;
            padding: 3rem;
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            box-shadow: 0 30px 60px -15px rgba(0, 0, 0, 0.6);
        }

        .form-header-block {
            margin-bottom: 2.5rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding-bottom: 1.5rem;
        }

        .form-header-block h2 {
            font-size: 1.65rem;
            font-weight: 700;
            color: #ffffff;
            display: flex;
            align-items: center;
            gap: 0.85rem;
            letter-spacing: -0.025em;
        }

        .form-header-block p {
            color: var(--text-muted);
            font-size: 0.875rem;
            margin-top: 0.5rem;
            line-height: 1.6;
        }

        /* Advanced Input Shell & Floating Labels */
        .interactive-input-group {
            position: relative;
            margin-bottom: 2.25rem;
            display: flex;
            flex-direction: column;
        }

        .input-shell {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-shell i {
            position: absolute;
            left: 1.35rem;
            color: rgba(156, 163, 175, 0.4);
            font-size: 1.05rem;
            transition: var(--transition-smooth);
            pointer-events: none;
            z-index: 2;
        }

        .form-control-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.09);
            border-radius: 14px;
            padding: 1.3rem 1rem 1.3rem 3.5rem;
            color: #ffffff;
            font-family: var(--font-stack);
            font-size: 0.95rem;
            transition: var(--transition-smooth);
        }

        /* Client-Side Live Validation Glow Engine */
        .form-control-input:valid {
            border-color: rgba(16, 185, 129, 0.4);
            background: rgba(16, 185, 129, 0.01);
        }

        .form-control-input:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.04);
            border-color: #0ea5e9;
            box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.18);
        }

        .floating-label {
            position: absolute;
            left: 3.5rem;
            top: 50%;
            transform: translateY(-50%);
            color: rgba(156, 163, 175, 0.55);
            font-size: 0.95rem;
            pointer-events: none;
            transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
            z-index: 2;
        }

        /* Float Locking configurations for instant data binding */
        .form-control-input:focus ~ .floating-label,
        .form-control-input:not(:placeholder-shown) ~ .floating-label,
        .form-control-input:valid ~ .floating-label {
            top: -0.55rem;
            left: 1.15rem;
            transform: translateY(0) scale(0.8);
            background: #090f1c;
            padding: 0 0.45rem;
            font-weight: 600;
        }

        .form-control-input:focus ~ .floating-label { color: #0ea5e9; }
        .form-control-input:valid ~ .floating-label { color: #10b981; }

        .form-control-input:focus ~ i {
            color: #0ea5e9;
            transform: scale(1.08);
        }

        /* Commit Transaction Actions Wrapper */
        .btn-registry-update {
            width: 100%;
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: #ffffff;
            border: none;
            border-radius: 14px;
            padding: 1.15rem;
            font-family: var(--font-stack);
            font-size: 1rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.65rem;
            box-shadow: 0 4px 15px rgba(14, 165, 233, 0.3);
            transition: var(--transition-smooth);
            margin-top: 0.5rem;
        }

        .btn-registry-update:hover {
            background: linear-gradient(135deg, #38bdf8 0%, #0ea5e9 100%);
            box-shadow: 0 10px 25px rgba(14, 165, 233, 0.45);
            transform: translateY(-2px);
            /* Dynamic physics wiggle on core mutation save trigger */
            animation: macroWiggle 0.6s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
        }

        /* --- High Fidelity Animation Framework Keyframes --- */
        @keyframes consoleEntrance {
            from { opacity: 0; transform: translateY(22px); filter: blur(5px); }
            to { opacity: 1; transform: translateY(0); filter: blur(0); }
        }

        /* Macro physics vibration mechanical formulation */
        @keyframes macroWiggle {
            10%, 90% { transform: translate3d(-1px, 0, 0); }
            20%, 80% { transform: translate3d(1.5px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-2px, 0, 0); }
            40%, 60% { transform: translate3d(2px, 0, 0); }
        }
    </style>
</head>
<body>
    <div class="bg-overlay"></div>

    <div class="form-page-wrapper">
        <header class="top-utility-bar">
            <a href="/medIntimate/staffs" class="btn-utility-nav">
                <i class="fa-solid fa-arrow-left-long"></i> Cancel & Return
            </a>
            <a href="/medIntimate" class="btn-utility-nav">
                <i class="fa-solid fa-chart-pie"></i> Workspace Dashboard
            </a>
        </header>

        <main class="premium-form-card">
            <header class="form-header-block">
                <h2><i class="fa-solid fa-user-gear" style="color: #0ea5e9;"></i> Revise Practitioner Account</h2>
                <p>Modifying node fields for system verification token reference ID: <code style="color: #38bdf8; font-family: monospace; background: rgba(255,255,255,0.04); padding: 0.15rem 0.4rem; border-radius: 6px;"><%= staff._id %></code></p>
            </header>

            <form method="POST" action="/medIntimate/staffs/<%= staff._id %>?_method=PUT">
                
                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="text" id="name" name="staffName" class="form-control-input" value="<%= staff.staffName %>" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-user-md"></i>
                        <label for="name" class="floating-label">Staff Full Name</label>
                    </div>
                </div>

                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="text" id="desg" name="designation" class="form-control-input" value="<%= staff.designation %>" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-briefcase-medical"></i>
                        <label for="desg" class="floating-label">Designation / Role Title</label>
                    </div>
                </div>

                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="text" id="ph" name="phone" pattern="[0-9]{10,}" class="form-control-input" value="<%= staff.phone %>" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-phone-square-alt"></i>
                        <label for="ph" class="floating-label">Secure Contact Extension (Phone)</label>
                    </div>
                </div>

                <div class="interactive-input-group">
                    <div class="input-shell">
                        <input type="url" id="img" name="image" class="form-control-input" value="<%= staff.image %>" placeholder=" " required autocomplete="off">
                        <i class="fa-solid fa-image-portrait"></i>
                        <label for="img" class="floating-label">Profile Image Asset URI</label>
                    </div>
                </div>

                <button type="submit" class="btn-registry-update">
                    <span>Commit Changes & Re-Authorize</span>
                    <i class="fa-solid fa-shield-halved"></i>
                </button>
            </form>
        </main>
    </div>
</body>
</html>