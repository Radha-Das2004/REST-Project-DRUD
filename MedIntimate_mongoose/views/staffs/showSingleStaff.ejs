<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedIntimate — Profile: <%= staff.staffName %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="/style.css">
    
    <style>
        .profile-page-container {
            width: 100%;
            max-width: 1200px;
            margin: 3rem auto;
            padding: 0 1.5rem;
            animation: viewEntrance 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        /* Navigation Control Header */
        .profile-nav-header {
            display: flex;
            justify-content: flex-start;
            margin-bottom: 2.5rem;
        }

        .btn-directory-back {
            color: #ffffff;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 0.65rem;
            padding: 0.75rem 1.5rem;
            background: rgba(30, 41, 59, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            transition: var(--transition-smooth);
        }

        .btn-directory-back:hover {
            background: rgba(30, 41, 59, 0.7);
            border-color: #0ea5e9;
            transform: translateX(-4px);
            box-shadow: 0 0 15px rgba(14, 165, 233, 0.2);
        }

        /* Main Structural Split Layout */
        .profile-layout-grid {
            display: grid;
            grid-template-columns: 380px 1fr;
            gap: 2.5rem;
            align-items: start;
        }

        @media (max-width: 968px) {
            .profile-layout-grid {
                grid-template-columns: 1fr;
            }
        }

        /* --- Column 1: Core Practitioner Workspace Focus Card --- */
        .practitioner-focus-card {
            background: linear-gradient(145deg, rgba(15, 23, 42, 0.85) 0%, rgba(17, 24, 39, 0.75) 100%);
            border: 1px solid rgba(255, 255, 255, 0.09);
            border-radius: 28px;
            padding: 3rem 2rem;
            text-align: center;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 25px 55px rgba(0, 0, 0, 0.45);
            position: relative;
            transition: var(--transition-smooth);
        }

        .practitioner-focus-card:hover {
            border-color: rgba(14, 165, 233, 0.25);
            box-shadow: 0 30px 65px rgba(14, 165, 233, 0.06);
        }

        .profile-avatar-wrapper {
            position: relative;
            width: 150px;
            height: 150px;
            margin: 0 auto 1.75rem auto;
            border-radius: 50%;
            padding: 4px;
            background: linear-gradient(135deg, #0ea5e9 0%, #10b981 100%);
            box-shadow: 0 8px 24px rgba(14, 165, 233, 0.2);
            transition: var(--transition-smooth);
        }

        .practitioner-focus-card:hover .profile-avatar-wrapper {
            transform: scale(1.03) rotate(2deg);
        }

        .profile-avatar-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            background: #111827;
        }

        .practitioner-focus-card h2 {
            font-size: 1.65rem;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.025em;
        }

        .practitioner-role-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            margin-top: 0.65rem;
            background: rgba(14, 165, 233, 0.12);
            border: 1px solid rgba(14, 165, 233, 0.25);
            color: #38bdf8;
            padding: 0.35rem 1.25rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 0.05em;
            text-transform: uppercase;
        }

        .practitioner-meta-details {
            margin-top: 2.5rem;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
            padding-top: 1.75rem;
            text-align: left;
            display: flex;
            flex-direction: column;
            gap: 1.2rem;
        }

        .meta-detail-row {
            display: flex;
            align-items: flex-start;
            gap: 1rem;
            color: var(--text-main);
            font-size: 0.9rem;
            background: rgba(255, 255, 255, 0.01);
            padding: 0.75rem 1rem;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.02);
        }

        .meta-detail-row i {
            color: #38bdf8;
            font-size: 1rem;
            margin-top: 0.15rem;
            width: 20px;
            text-align: center;
        }

        .meta-detail-label {
            display: block;
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 500;
            margin-bottom: 0.15rem;
            text-transform: uppercase;
            letter-spacing: 0.02em;
        }

        .meta-detail-value {
            font-weight: 600;
            word-break: break-all;
        }

        /* Inline Profile Management Triggers */
        .profile-management-actions {
            margin-top: 2rem;
            display: grid;
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        .btn-action-trigger {
            padding: 0.85rem;
            border-radius: 12px;
            font-size: 0.9rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            transition: var(--transition-smooth);
        }

        .btn-profile-edit {
            background: rgba(14, 165, 233, 0.1);
            color: #38bdf8;
            border: 1px solid rgba(14, 165, 233, 0.2);
        }

        /* Added Physics-Based Wiggle Feedback on key actions */
        .btn-profile-edit:hover {
            background: #0ea5e9;
            color: #ffffff;
            box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);
            animation: physicsWiggle 0.6s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
        }

        /* --- Column 2: Connected Case Roster Ledger --- */
        .roster-ledger-card {
            background: rgba(17, 24, 39, 0.55);
            border: 1px solid rgba(255, 255, 255, 0.06);
            border-radius: 28px;
            padding: 3rem;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 25px 55px rgba(0, 0, 0, 0.3);
        }

        .roster-header {
            margin-bottom: 2rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding-bottom: 1.25rem;
        }

        .roster-header h3 {
            font-size: 1.35rem;
            font-weight: 700;
            color: #ffffff;
            display: flex;
            align-items: center;
            gap: 0.85rem;
        }

        .case-count-pill {
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.2);
            padding: 0.2rem 0.75rem;
            border-radius: 20px;
            font-size: 0.8rem;
            color: #34d399;
            font-weight: 600;
        }

        .patient-roster-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.25rem;
        }

        .assigned-patient-pill {
            background: linear-gradient(to right, rgba(255, 255, 255, 0.01), rgba(255, 255, 255, 0.02));
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 18px;
            padding: 1.25rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: var(--transition-smooth);
        }

        /* Physics Wiggle triggered smoothly on case layout selection */
        .assigned-patient-pill:hover {
            background: rgba(255, 255, 255, 0.03);
            border-color: rgba(16, 185, 129, 0.3);
            transform: scale(1.01);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            animation: physicsWiggle 0.5s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
        }

        .patient-identity-block {
            display: flex;
            align-items: center;
            gap: 1.25rem;
        }

        .patient-avatar-clip {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            object-fit: cover;
            background: #1f2937;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .patient-text-info h4 {
            font-size: 1.05rem;
            font-weight: 600;
            color: #ffffff;
            letter-spacing: -0.01em;
        }

        .patient-text-info p {
            font-size: 0.85rem;
            color: var(--text-muted);
            margin-top: 0.25rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .patient-text-info p i {
            color: rgba(14, 165, 233, 0.7);
        }

        .claim-status-badge {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 0.35rem 1rem;
            border-radius: 8px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        }

        /* Visual State mappings using realistic palettes */
        .status-approved {
            background: rgba(16, 185, 129, 0.1);
            color: #34d399;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }

        .status-pending {
            background: rgba(245, 158, 11, 0.1);
            color: #fbbf24;
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        .empty-roster-state {
            text-align: center;
            padding: 5rem 2rem;
            color: var(--text-muted);
            font-size: 0.95rem;
            border: 1px dashed rgba(255, 255, 255, 0.08);
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.01);
        }

        .empty-roster-state i {
            font-size: 3rem;
            margin-bottom: 1.25rem;
            color: rgba(255, 255, 255, 0.08);
        }

        /* --- High-Fidelity Custom Animation Frames --- */
        @keyframes viewEntrance {
            from { opacity: 0; transform: translateY(20px); filter: blur(5px); }
            to { opacity: 1; transform: translateY(0); filter: blur(0); }
        }

        /* Physics-based realistic micro-viggle mechanical formulation */
        @keyframes physicsWiggle {
            10%, 90% { transform: translate3d(-1px, 0, 0); }
            20%, 80% { transform: translate3d(2px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-3px, 0, 0); }
            40%, 60% { transform: translate3d(3px, 0, 0); }
        }
    </style>
</head>
<body>
    <div class="bg-overlay"></div>

    <div class="profile-page-container">
        <nav class="profile-nav-header">
            <a href="/medIntimate/staffs" class="btn-directory-back">
                <i class="fa-solid fa-arrow-left-long"></i>
                <span>Return to Staff Ledger</span>
            </a>
        </nav>

        <div class="profile-layout-grid">
            
            <aside class="practitioner-focus-card">
                <div class="profile-avatar-wrapper">
                    <img src="<%= staff.image ? staff.image : 'https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&w=256&q=80' %>" alt="<%= staff.staffName %>">
                </div>
                <h2><%= staff.staffName %></h2>
                <span class="practitioner-role-badge">
                    <i class="fa-solid fa-user-check"></i> <%= staff.designation %>
                </span>

                <div class="practitioner-meta-details">
                    <div class="meta-detail-row">
                        <i class="fa-solid fa-fingerprint"></i>
                        <div>
                            <span class="meta-detail-label">Database Unique ID</span>
                            <span class="meta-detail-value"><%= staff._id %></span>
                        </div>
                    </div>
                    <div class="meta-detail-row">
                        <i class="fa-solid fa-phone-flip"></i>
                        <div>
                            <span class="meta-detail-label">Communications Line</span>
                            <span class="meta-detail-value"><%= staff.phone %></span>
                        </div>
                    </div>
                    <div class="meta-detail-row">
                        <i class="fa-solid fa-shield-halved"></i>
                        <div>
                            <span class="meta-detail-label">System Access Rank</span>
                            <span class="meta-detail-value">Verified Medical Professional</span>
                        </div>
                    </div>
                </div>

                <div class="profile-management-actions">
                    <a href="/medIntimate/staffs/<%= staff._id %>/edit" class="btn-action-trigger btn-profile-edit">
                        <i class="fa-solid fa-user-gear"></i> Modify Profile Credentials
                    </a>
                </div>
            </aside>

            <main class="roster-ledger-card">
                <header class="roster-header">
                    <h3>
                        <i class="fa-solid fa-network-wired" style="color: #0ea5e9;"></i> 
                        <span>Assigned Cases Engine</span>
                        <span class="case-count-pill"><%= patient.length %> Active Allocations</span>
                    </h3>
                </header>

                <div class="patient-roster-grid">
                    <% if(typeof patient !== 'undefined' && patient.length > 0) { %>
                        <% for(let activePatient of patient) { %>
                            <div class="assigned-patient-pill">
                                <div class="patient-identity-block">
                                    <img class="patient-avatar-clip" src="<%= activePatient.image ? activePatient.image : 'https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&w=120&q=80' %>" alt="">
                                    <div class="patient-text-info">
                                        <h4><%= activePatient.patientName %></h4>
                                        <p>
                                            <i class="fa-solid fa-notes-medical"></i> 
                                            <span><strong>Diagnosis/Reason:</strong> <%= activePatient.reason %></span>
                                        </p>
                                    </div>
                                </div>
                                <span class="claim-status-badge <%= activePatient.claimStatus === 'Approved' ? 'status-approved' : 'status-pending' %>">
                                    <i class="fa-solid <%= activePatient.claimStatus === 'Approved' ? 'fa-circle-check' : 'fa-circle-notch fa-spin' %>" style="margin-right: 4px;"></i>
                                    <%= activePatient.claimStatus || 'Awaiting Triage' %>
                                </span>
                            </div>
                        <% } %>
                    <% } else { %>
                        <div class="empty-roster-state">
                            <i class="fa-solid fa-hospital-user"></i>
                            <p>No medical cases are currently routed directly to this provider's station ledger.</p>
                        </div>
                    <% } %>
                </div>
            </main>

        </div>
    </div>
</body>
</html>