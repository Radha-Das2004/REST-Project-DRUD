<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedIntimate — Staff Directory</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --teal-800: #0a4a43; --teal-700: #0f6b60; --teal-500: #1cab97;
            --teal-400: #3fc9b4; --mint-300: #8fe9d6;
            --bg-deep: #071a1d;
            --surface: rgba(255,255,255,0.045);
            --surface-strong: rgba(255,255,255,0.08);
            --border-soft: rgba(143,233,214,0.16);
            --text-primary: #eafffa; --text-muted: #9fc7c0;
            --danger: #ff6b6b; --danger-soft: rgba(255,107,107,0.12);
            --ok: #4ee2a4;
            --shadow-glow: 0 0 0 1px rgba(143,233,214,0.08), 0 20px 60px -20px rgba(0,0,0,0.6);
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0; padding: 0; min-height: 100vh;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-primary);
            background-color: var(--bg-deep);
        }

        body {
            background-image:
                linear-gradient(180deg, rgba(4,18,20,0.92) 0%, rgba(4,24,24,0.95) 45%, rgba(2,12,13,0.98) 100%),
                url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed; inset: 0;
            background:
                radial-gradient(900px 500px at 12% -5%, rgba(28,171,151,0.20), transparent 60%),
                radial-gradient(700px 500px at 110% 10%, rgba(63,201,180,0.14), transparent 60%);
            pointer-events: none; z-index: 0;
        }

        .shell {
            position: relative; z-index: 1;
            max-width: 1280px;
            margin: 0 auto;
            padding: 38px 28px 80px;
        }

        /* ── Header ── */
        .view-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 36px;
            padding-bottom: 24px;
            border-bottom: 1px solid rgba(143,233,214,0.1);
            animation: slideDown 0.7s cubic-bezier(.16,1,.3,1) both;
        }

        .eyebrow {
            display: inline-flex; align-items: center; gap: 8px;
            font-size: 0.72rem; letter-spacing: 0.14em;
            text-transform: uppercase; color: var(--mint-300);
            font-weight: 700; margin-bottom: 8px;
        }

        .view-title h2 {
            font-family: 'Sora', sans-serif;
            font-size: clamp(1.5rem, 2.5vw, 2rem);
            font-weight: 800; margin: 0 0 5px;
            display: flex; align-items: center; gap: 12px;
            background: linear-gradient(95deg, #ffffff 10%, var(--mint-300) 90%);
            -webkit-background-clip: text; background-clip: text; color: transparent;
        }
        .view-title h2 i { color: var(--teal-400); font-size: 1.3rem; }
        .view-title p { color: var(--text-muted); font-size: 0.88rem; margin: 0; }

        .action-controls-group { display: flex; align-items: center; gap: 12px; }

        .btn-nav {
            display: inline-flex; align-items: center; gap: 9px;
            padding: 11px 18px; border-radius: 13px;
            font-weight: 700; font-size: 0.88rem;
            text-decoration: none; border: none; cursor: pointer;
            font-family: 'Plus Jakarta Sans', sans-serif;
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
            position: relative; overflow: hidden;
        }
        .btn-nav::before {
            content: "";
            position: absolute; inset: 0;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.15), transparent);
            transform: translateX(-120%);
            transition: transform 0.55s ease;
        }
        .btn-nav:hover::before { transform: translateX(120%); }
        .btn-nav i { transition: transform 0.28s ease; }

        .btn-dashboard {
            background: var(--surface); color: var(--text-primary);
            border: 1px solid var(--border-soft);
        }
        .btn-dashboard:hover {
            background: var(--surface-strong); border-color: var(--teal-500);
            transform: translateY(-2px);
        }

        .btn-add {
            background: linear-gradient(135deg, var(--teal-500), var(--teal-700));
            color: #06231f;
            box-shadow: 0 10px 28px -8px rgba(28,171,151,0.55);
        }
        .btn-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 16px 36px -8px rgba(28,171,151,0.72);
        }
        .btn-add:hover i { transform: rotate(15deg); }

        /* ── Grid ── */
        .staff-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
            gap: 22px;
        }

        /* ── Card ── */
        .staff-profile-card {
            position: relative;
            background: linear-gradient(165deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
            border: 1px solid var(--border-soft);
            border-radius: 20px; padding: 22px;
            display: flex; flex-direction: column;
            justify-content: space-between;
            box-shadow: var(--shadow-glow);
            overflow: hidden;
            opacity: 0;
            transition: transform 0.4s cubic-bezier(.34,1.56,.64,1), border-color 0.3s ease, box-shadow 0.3s ease;
        }

        /* Gradient border on hover */
        .staff-profile-card::after {
            content: "";
            position: absolute; inset: -1px; border-radius: 20px; padding: 1px;
            background: linear-gradient(135deg, rgba(63,201,180,0), rgba(63,201,180,0.55), rgba(63,201,180,0));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask-composite: exclude;
            opacity: 0; transition: opacity 0.35s ease; pointer-events: none;
        }

        /* Shimmer sweep */
        .staff-profile-card .shimmer {
            position: absolute; inset: 0;
            background: linear-gradient(105deg, transparent 40%, rgba(143,233,214,0.07) 50%, transparent 60%);
            transform: translateX(-100%);
            border-radius: 20px; pointer-events: none;
            animation: shimmer 3.8s ease infinite;
        }

        .staff-profile-card:hover {
            transform: translateY(-7px) scale(1.013);
            border-color: rgba(143,233,214,0.38);
            box-shadow: 0 26px 54px -18px rgba(28,171,151,0.48);
        }
        .staff-profile-card:hover::after { opacity: 1; }
        .staff-profile-card:hover .avatar-frame { transform: scale(1.08) rotate(-2deg); }

        .card-main-info {
            display: flex; align-items: center; gap: 16px;
            margin-bottom: 14px;
        }

        .avatar-frame {
            width: 64px; height: 64px;
            border-radius: 50%; padding: 2px; flex-shrink: 0;
            background: linear-gradient(135deg, var(--teal-500), rgba(143,233,214,0.3));
            transition: transform 0.4s cubic-bezier(.34,1.56,.64,1);
        }
        .avatar-frame img {
            width: 100%; height: 100%;
            border-radius: 50%; object-fit: cover;
            background: var(--teal-800); display: block;
        }

        .info-meta h3 {
            font-size: 1.05rem; font-weight: 700;
            color: var(--text-primary); margin: 0 0 5px;
        }

        .badge-designation {
            display: inline-block;
            background: rgba(28,171,151,0.14); color: var(--teal-400);
            border: 1px solid rgba(63,201,180,0.25);
            padding: 3px 10px; border-radius: 6px;
            font-size: 0.68rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.05em;
        }

        .contact-row {
            display: flex; align-items: center; gap: 9px;
            color: var(--text-muted); font-size: 0.83rem;
            background: rgba(255,255,255,0.04);
            padding: 9px 13px; border-radius: 11px;
            margin-bottom: 16px;
        }
        .contact-row i { color: var(--ok); font-size: 0.8rem; }

        /* ── Action Hub ── */
        .action-hub {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            border-top: 1px solid rgba(143,233,214,0.1);
            padding-top: 16px;
        }

        .action-link {
            display: inline-flex; align-items: center; justify-content: center;
            gap: 7px; padding: 9px 12px; border-radius: 11px;
            font-size: 0.8rem; font-weight: 700; text-decoration: none;
            border: 1px solid transparent;
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
        }
        .action-link i { transition: transform 0.28s cubic-bezier(.34,1.56,.64,1); }
        .action-link:hover i { transform: scale(1.2); }

        .btn-view-profile {
            grid-column: span 2;
            background: rgba(255,255,255,0.05); color: var(--text-primary);
            border-color: rgba(143,233,214,0.15);
            margin-bottom: 2px;
        }
        .btn-view-profile:hover { background: rgba(255,255,255,0.1); border-color: var(--teal-500); }

        .btn-edit-staff {
            background: rgba(28,171,151,0.1); color: var(--teal-400);
            border-color: rgba(63,201,180,0.2);
        }
        .btn-edit-staff:hover { background: var(--teal-500); color: #06231f; transform: translateY(-2px); }

        .btn-delete-staff {
            background: var(--danger-soft); color: #ff8a8a;
            border-color: rgba(255,107,107,0.2);
        }
        .btn-delete-staff:hover { background: var(--danger); color: #fff; transform: translateY(-2px); }

        /* ── Empty State ── */
        .empty-state {
            grid-column: 1 / -1;
            text-align: center; padding: 70px 20px;
            border: 1px dashed var(--border-soft);
            border-radius: 20px; background: var(--surface);
            animation: fadeSlideUp 0.6s ease forwards;
        }
        .empty-state i { font-size: 2.4rem; color: var(--teal-500); margin-bottom: 14px; display: block; }
        .empty-state h3 { font-family: 'Sora', sans-serif; color: var(--text-primary); margin: 0 0 6px; }
        .empty-state p { color: var(--text-muted); margin: 0; font-size: 0.9rem; }

        /* ── Keyframes ── */
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(26px) scale(0.96); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes shimmer {
            0%        { transform: translateX(-100%); }
            50%, 100% { transform: translateX(100%); }
        }

        @media (max-width: 720px) {
            .view-header { flex-direction: column; align-items: flex-start; }
            .action-controls-group { width: 100%; }
            .btn-nav { flex: 1; justify-content: center; }
        }
    </style>
</head>
<body>
    <div class="shell">

        <header class="view-header">
            <div class="view-title">
                <div class="eyebrow"><i class="fa-solid fa-heart-pulse"></i> MedIntimate · Staff Registry</div>
                <h2><i class="fa-solid fa-users-rectangle"></i> Staff Directory</h2>
                <p>Manage medical specialists, operational credentials, and resource deployment</p>
            </div>
            <div class="action-controls-group">
                <a href="/medIntimate" class="btn-nav btn-dashboard">
                    <i class="fa-solid fa-chart-pie"></i> Dashboard
                </a>
                <a href="/medIntimate/staffs/new" class="btn-nav btn-add">
                    <i class="fa-solid fa-user-plus"></i> Add New Staff
                </a>
            </div>
        </header>

        <main class="staff-grid">
            <% if (typeof staffs !== 'undefined' && staffs.length > 0) { %>
                <% staffs.forEach(function(staff, idx) {
                    const delay = (0.15 + idx * 0.08).toFixed(2);
                %>
                <article class="staff-profile-card" style="animation: cardIn 0.65s cubic-bezier(.16,1,.3,1) <%= delay %>s both;">
                    <div class="shimmer" style="animation-delay: <%= (idx * 0.5).toFixed(1) %>s;"></div>

                    <div>
                        <div class="card-main-info">
                            <div class="avatar-frame">
                                <img
                                    src="<%= staff.image || 'https://images.unsplash.com/photo-1622253692010-333f2da6031d?auto=format&fit=crop&w=256&q=80' %>"
                                    alt="<%= staff.staffName %>">
                            </div>
                            <div class="info-meta">
                                <h3><%= staff.staffName %></h3>
                                <span class="badge-designation"><%= staff.designation %></span>
                            </div>
                        </div>

                        <div class="contact-row">
                            <i class="fa-solid fa-phone-flip"></i>
                            <span><%= staff.phone %></span>
                        </div>
                    </div>

                    <div class="action-hub">
                        <a href="/medIntimate/staffs/<%= staff._id %>" class="action-link btn-view-profile">
                            <i class="fa-solid fa-address-card"></i> View Full Details
                        </a>
                        <a href="/medIntimate/staffs/<%= staff._id %>/edit" class="action-link btn-edit-staff">
                            <i class="fa-solid fa-user-pen"></i> Edit
                        </a>
                        <a href="/medIntimate/staffs/<%= staff._id %>/delete" class="action-link btn-delete-staff">
                            <i class="fa-solid fa-user-xmark"></i> Delete
                        </a>
                    </div>
                </article>
                <% }); %>
            <% } else { %>
                <div class="empty-state">
                    <i class="fa-solid fa-folder-open"></i>
                    <h3>No staff records found</h3>
                    <p>Add medical team personnel to view them here.</p>
                </div>
            <% } %>
        </main>

    </div>
</body>
</html>