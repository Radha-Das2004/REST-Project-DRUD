<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedIntimate | Dashboard</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --teal-800: #0a4a43; --teal-700: #0f6b60; --teal-500: #1cab97;
            --teal-400: #3fc9b4; --mint-300: #8fe9d6;
            --bg-deep: #071a1d;
            --surface: rgba(255,255,255,0.045);
            --surface-strong: rgba(255,255,255,0.08);
            --border-soft: rgba(143,233,214,0.16);
            --text-primary: #eafffa; --text-muted: #9fc7c0;
            --ok: #4ee2a4; --ok-soft: rgba(78,226,164,0.12);
            --shadow-glow: 0 0 0 1px rgba(143,233,214,0.08), 0 20px 60px -20px rgba(0,0,0,0.6);
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0; padding: 0; min-height: 100vh;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-primary);
            background-color: var(--bg-deep);
        }

        body {
            background-image:
                linear-gradient(180deg, rgba(4,18,20,0.92) 0%, rgba(4,24,24,0.95) 45%, rgba(2,12,13,0.98) 100%),
                url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed; inset: 0;
            background:
                radial-gradient(900px 500px at 12% -5%, rgba(28,171,151,0.20), transparent 60%),
                radial-gradient(700px 500px at 110% 10%, rgba(63,201,180,0.14), transparent 60%);
            pointer-events: none; z-index: 0;
        }

        .shell {
            position: relative; z-index: 1;
            max-width: 900px;
            margin: 0 auto;
            padding: 48px 28px 80px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ── Header ── */
        .dashboard-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            margin-bottom: 56px;
            animation: slideDown 0.7s cubic-bezier(.16,1,.3,1) both;
        }

        .brand-wrapper { display: flex; align-items: center; gap: 18px; }

        .logo-icon {
            width: 54px; height: 54px;
            border-radius: 16px;
            background: var(--teal-800);
            border: 1px solid var(--border-soft);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.35rem; color: var(--teal-400);
            animation: logoPop 0.8s cubic-bezier(.34,1.56,.64,1) 0.2s both;
        }

        .brand-wrapper h1 {
            font-family: 'Sora', sans-serif;
            font-size: 1.6rem; font-weight: 800;
            margin: 0 0 4px;
            background: linear-gradient(95deg, #ffffff 10%, var(--mint-300) 90%);
            -webkit-background-clip: text; background-clip: text; color: transparent;
            animation: fadeRight 0.6s ease 0.3s both;
        }

        .subtitle {
            margin: 0; font-size: 0.8rem; color: var(--text-muted);
            animation: fadeRight 0.6s ease 0.4s both;
        }

        .system-status {
            display: flex; align-items: center; gap: 9px;
            padding: 9px 16px; border-radius: 100px;
            background: var(--ok-soft);
            border: 1px solid rgba(78,226,164,0.25);
            color: var(--ok); font-size: 0.82rem; font-weight: 700;
            animation: fadeIn 0.6s ease 0.5s both;
        }

        .status-indicator {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--ok);
            animation: pulse 2s ease infinite;
        }

        /* ── Cards ── */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px; flex: 1;
        }

        .metric-card {
            position: relative;
            background: linear-gradient(160deg, rgba(255,255,255,0.065), rgba(255,255,255,0.02));
            border: 1px solid var(--border-soft);
            border-radius: 24px; padding: 30px;
            overflow: hidden;
            box-shadow: var(--shadow-glow);
            transition: transform 0.4s cubic-bezier(.34,1.56,.64,1), border-color 0.3s ease, box-shadow 0.3s ease;
        }

        /* Gradient border on hover */
        .metric-card::after {
            content: "";
            position: absolute; inset: -1px; border-radius: 24px; padding: 1px;
            background: linear-gradient(135deg, rgba(63,201,180,0), rgba(63,201,180,0.55), rgba(63,201,180,0));
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask-composite: exclude;
            opacity: 0; transition: opacity 0.35s ease; pointer-events: none;
        }

        /* Shimmer sweep */
        .metric-card .shimmer {
            position: absolute; inset: 0;
            background: linear-gradient(105deg, transparent 40%, rgba(143,233,214,0.06) 50%, transparent 60%);
            transform: translateX(-100%);
            border-radius: 24px; pointer-events: none;
            animation: shimmer 3.5s ease infinite;
        }

        .staff-card  { animation: cardIn 0.7s cubic-bezier(.16,1,.3,1) 0.35s both; }
        .patient-card { animation: cardIn 0.7s cubic-bezier(.16,1,.3,1) 0.5s both; }

        .metric-card:hover { transform: translateY(-8px) scale(1.015); border-color: rgba(143,233,214,0.4); box-shadow: 0 28px 56px -18px rgba(28,171,151,0.5); }
        .metric-card:hover::after { opacity: 1; }
        .metric-card:hover .card-header-icon { transform: scale(1.12) rotate(-4deg); }

        .card-header-icon {
            width: 50px; height: 50px; border-radius: 15px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.25rem; margin-bottom: 20px;
            transition: transform 0.4s cubic-bezier(.34,1.56,.64,1);
        }

        .staff-card  .card-header-icon { background: rgba(28,171,151,0.16); color: var(--teal-400); }
        .patient-card .card-header-icon { background: rgba(143,233,214,0.10); color: var(--mint-300); }

        .card-content h3 {
            font-size: 0.74rem; text-transform: uppercase;
            letter-spacing: 0.1em; color: var(--text-muted);
            font-weight: 700; margin: 0 0 8px;
        }

        .counter {
            display: block;
            font-family: 'Sora', sans-serif;
            font-size: 3.2rem; font-weight: 800; line-height: 1;
            background: linear-gradient(120deg, #ffffff, var(--mint-300));
            -webkit-background-clip: text; background-clip: text; color: transparent;
            margin-bottom: 8px;
        }

        .card-meta { font-size: 0.82rem; color: var(--text-muted); margin: 0 0 26px; }

        /* ── Buttons ── */
        .btn {
            display: inline-flex; align-items: center; gap: 10px;
            padding: 12px 20px; border-radius: 13px; text-decoration: none;
            font-weight: 700; font-size: 0.9rem;
            transition: all 0.3s cubic-bezier(.4,0,.2,1);
            position: relative; overflow: hidden;
        }

        .btn::before {
            content: "";
            position: absolute; inset: 0;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.18), transparent);
            transform: translateX(-120%);
            transition: transform 0.55s ease;
        }
        .btn:hover::before { transform: translateX(120%); }

        .btn i { transition: transform 0.3s cubic-bezier(.34,1.56,.64,1); }
        .btn:hover i { transform: translateX(5px); }

        .btn-primary {
            background: linear-gradient(135deg, var(--teal-500), var(--teal-700));
            color: #06231f;
            box-shadow: 0 10px 28px -8px rgba(28,171,151,0.55);
        }
        .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 16px 36px -8px rgba(28,171,151,0.72); }

        .btn-secondary {
            background: rgba(143,233,214,0.10); color: var(--mint-300);
            border: 1px solid rgba(143,233,214,0.22);
        }
        .btn-secondary:hover { background: rgba(143,233,214,0.18); border-color: var(--teal-400); transform: translateY(-2px); }

        /* ── Footer ── */
        .dashboard-footer {
            margin-top: 56px; text-align: center;
            font-size: 0.76rem; color: rgba(143,233,214,0.3);
            padding-top: 20px;
            border-top: 1px solid rgba(143,233,214,0.08);
            animation: fadeIn 0.6s ease 0.9s both;
        }

        .divider-line {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--border-soft), transparent);
            margin: 2rem 0;
            animation: expandLine 0.8s ease 0.7s both;
            transform-origin: center;
        }

        /* ── Keyframes ── */
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-18px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeRight {
            from { opacity: 0; transform: translateX(-10px); }
            to   { opacity: 1; transform: translateX(0); }
        }
        @keyframes fadeIn {
            from { opacity: 0; } to { opacity: 1; }
        }
        @keyframes logoPop {
            from { opacity: 0; transform: scale(0.5) rotate(-10deg); }
            to   { opacity: 1; transform: scale(1) rotate(0deg); }
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(28px) scale(0.96); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }
        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(78,226,164,0.5); }
            50%       { box-shadow: 0 0 0 6px rgba(78,226,164,0); }
        }
        @keyframes shimmer {
            0%       { transform: translateX(-100%); }
            50%, 100%{ transform: translateX(100%); }
        }
        @keyframes expandLine {
            from { transform: scaleX(0); opacity: 0; }
            to   { transform: scaleX(1); opacity: 1; }
        }

        @media (max-width: 600px) {
            .metrics-grid { grid-template-columns: 1fr; }
            .dashboard-header { flex-direction: column; align-items: flex-start; }
            .counter { font-size: 2.6rem; }
        }
    </style>
</head>
<body>
    <div class="shell">

        <header class="dashboard-header">
            <div class="brand-wrapper">
                <div class="logo-icon">
                    <i class="fa-solid fa-heart-pulse"></i>
                </div>
                <div>
                    <h1>MedIntimate</h1>
                    <p class="subtitle">Clinical Enterprise Management Workspace</p>
                </div>
            </div>
            <div class="system-status">
                <span class="status-indicator"></span> Live Operations
            </div>
        </header>

        <main class="metrics-grid">

            <div class="metric-card staff-card">
                <div class="shimmer"></div>
                <div class="card-header-icon">
                    <i class="fa-solid fa-user-doctor"></i>
                </div>
                <div class="card-content">
                    <h3>Active Staff</h3>
                    <span class="counter" id="staffCounter">0</span>
                    <p class="card-meta">Registered practitioners &amp; support</p>
                </div>
                <a href="/medIntimate/staffs" class="btn btn-primary">
                    View Directory <i class="fa-solid fa-arrow-right-long"></i>
                </a>
            </div>

            <div class="metric-card patient-card">
                <div class="shimmer" style="animation-delay: 0.4s;"></div>
                <div class="card-header-icon">
                    <i class="fa-solid fa-procedures"></i>
                </div>
                <div class="card-content">
                    <h3>Total Patients</h3>
                    <span class="counter" id="patientCounter">0</span>
                    <p class="card-meta">Active cases, triage, &amp; claims</p>
                </div>
                <a href="/medIntimate/patients" class="btn btn-secondary">
                    Patient Records <i class="fa-solid fa-arrow-right-long"></i>
                </a>
            </div>

        </main>

        <div class="divider-line"></div>

        <footer class="dashboard-footer">
            <p>&copy; 2026 MedIntimate System. All access logged and encrypted.</p>
        </footer>

    </div>

    <script>
        function animateCount(el, target, delay) {
            setTimeout(() => {
                let current = 0;
                const duration = 1200, step = 16;
                const increment = target / (duration / step);
                const timer = setInterval(() => {
                    current = Math.min(current + increment, target);
                    el.textContent = Math.round(current);
                    if (current >= target) clearInterval(timer);
                }, step);
            }, delay);
        }

        animateCount(document.getElementById('staffCounter'),   `<%= staff %>`,   700);
        animateCount(document.getElementById('patientCounter'), `<%= patient %>`, 850);
    </script>
</body>
</html>