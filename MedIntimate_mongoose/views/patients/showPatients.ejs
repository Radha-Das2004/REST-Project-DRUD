<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedIntimate | Patient Records</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --teal-950: #04211f;
            --teal-900: #06302c;
            --teal-800: #0a4a43;
            --teal-700: #0f6b60;
            --teal-600: #15897a;
            --teal-500: #1cab97;
            --teal-400: #3fc9b4;
            --mint-300: #8fe9d6;
            --bg-deep: #071a1d;
            --surface: rgba(255, 255, 255, 0.045);
            --surface-strong: rgba(255, 255, 255, 0.08);
            --border-soft: rgba(143, 233, 214, 0.16);
            --text-primary: #eafffa;
            --text-muted: #9fc7c0;
            --danger: #ff6b6b;
            --danger-soft: rgba(255, 107, 107, 0.12);
            --warn: #ffc861;
            --warn-soft: rgba(255, 200, 97, 0.12);
            --ok: #4ee2a4;
            --ok-soft: rgba(78, 226, 164, 0.12);
            --shadow-glow: 0 0 0 1px rgba(143,233,214,0.08), 0 20px 60px -20px rgba(0,0,0,0.6);
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-primary);
            background-color: var(--bg-deep);
        }

        body {
            position: relative;
            background-image:
                linear-gradient(180deg, rgba(4,18,20,0.92) 0%, rgba(4,24,24,0.95) 45%, rgba(2,12,13,0.98) 100%),
                url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background:
                radial-gradient(900px 500px at 12% -5%, rgba(28,171,151,0.20), transparent 60%),
                radial-gradient(700px 500px at 110% 10%, rgba(63,201,180,0.14), transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        .shell {
            position: relative;
            z-index: 1;
            max-width: 1280px;
            margin: 0 auto;
            padding: 38px 28px 80px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            flex-wrap: wrap;
            margin-bottom: 30px;
            opacity: 0;
            animation: fadeSlideDown 0.6s ease forwards;
        }

        .brand-back {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.92rem;
            padding: 9px 16px 9px 12px;
            border-radius: 100px;
            border: 1px solid var(--border-soft);
            background: var(--surface);
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
        }
        .brand-back i { transition: transform 0.28s ease; }
        .brand-back:hover {
            color: var(--mint-300);
            background: var(--surface-strong);
            border-color: var(--teal-500);
            box-shadow: 0 0 0 4px rgba(28,171,151,0.10);
            transform: translateY(-1px);
        }
        .brand-back:hover i { transform: translateX(-3px); }

        .header-block {
            opacity: 0;
            animation: fadeSlideUp 0.7s ease 0.05s forwards;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.72rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--mint-300);
            font-weight: 700;
            margin-bottom: 10px;
        }
        .eyebrow i { font-size: 0.8rem; }

        h1.page-title {
            font-family: 'Sora', sans-serif;
            font-size: clamp(1.7rem, 3vw, 2.4rem);
            margin: 0 0 6px;
            font-weight: 800;
            letter-spacing: -0.01em;
            background: linear-gradient(95deg, #ffffff 10%, var(--mint-300) 90%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .page-sub {
            margin: 0;
            color: var(--text-muted);
            font-size: 0.95rem;
        }

        .new-patient-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 13px 22px;
            border-radius: 14px;
            border: none;
            background: linear-gradient(135deg, var(--teal-500), var(--teal-700));
            color: #06231f;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            box-shadow: 0 10px 30px -8px rgba(28,171,151,0.55);
            transition: all 0.3s cubic-bezier(.4,0,.2,1);
            position: relative;
            overflow: hidden;
        }
        .new-patient-btn::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.35), transparent);
            transform: translateX(-120%);
            transition: transform 0.6s ease;
        }
        .new-patient-btn:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 16px 38px -8px rgba(28,171,151,0.7);
        }
        .new-patient-btn:hover::before { transform: translateX(120%); }
        .new-patient-btn:active { transform: translateY(0) scale(0.98); }

        .stats-strip {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 16px;
            margin-bottom: 34px;
        }
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border-soft);
            border-radius: 16px;
            padding: 18px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            opacity: 0;
            transform: translateY(14px);
            animation: fadeSlideUp 0.55s ease forwards;
            transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
        }
        .stat-card:hover {
            transform: translateY(-3px);
            border-color: var(--teal-500);
            box-shadow: 0 14px 34px -16px rgba(28,171,151,0.5);
        }
        .stat-icon {
            width: 42px; height: 42px;
            border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.05rem;
            flex-shrink: 0;
        }
        .stat-icon.total { background: rgba(28,171,151,0.16); color: var(--mint-300); }
        .stat-icon.approved { background: var(--ok-soft); color: var(--ok); }
        .stat-icon.pending { background: var(--warn-soft); color: var(--warn); }
        .stat-icon.unassigned { background: var(--danger-soft); color: var(--danger); }
        .stat-value { font-family: 'Sora', sans-serif; font-size: 1.3rem; font-weight: 800; line-height: 1; }
        .stat-label { font-size: 0.76rem; color: var(--text-muted); margin-top: 3px; }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
            gap: 22px;
        }

        .patient-card {
            position: relative;
            background: linear-gradient(165deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
            border: 1px solid var(--border-soft);
            border-radius: 20px;
            padding: 22px;
            backdrop-filter: blur(6px);
            box-shadow: var(--shadow-glow);
            opacity: 0;
            transform: translateY(22px);
            animation: cardIn 0.6s cubic-bezier(.16,1,.3,1) forwards;
            transition: transform 0.35s cubic-bezier(.4,0,.2,1), border-color 0.35s ease, box-shadow 0.35s ease;
        }

        .patient-card {
    position: relative; /* REQUIRED: Ensures the pseudo-element aligns to this card */
}

.patient-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: 20px;
    padding: 1px;
    background: linear-gradient(135deg, rgba(63,201,180,0), rgba(63,201,180,0.55), rgba(63,201,180,0));
    
    /* Masking to create the sharp 1px border effect */
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask-composite: exclude;
    
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
}

/* FIX: This triggers the gradient border to fade in when you hover over the card */
.patient-card:hover::after {
    opacity: 1;
}

        .patient-card:hover {
            transform: translateY(-6px) scale(1.012);
            border-color: rgba(143,233,214,0.35);
            box-shadow: 0 26px 60px -18px rgba(28,171,151,0.45), 0 0 0 1px rgba(143,233,214,0.12);
        }
        .patient-card:hover::after { opacity: 1; }

        .card-top {
            display: flex;
            align-items: center;
            gap: 14px;
            margin-bottom: 16px;
        }

        .avatar-wrap {
            width: 58px; height: 58px;
            border-radius: 16px;
            overflow: hidden;
            flex-shrink: 0;
            border: 1px solid var(--border-soft);
            background: var(--teal-900);
            display: flex; align-items: center; justify-content: center;
            transition: transform 0.35s ease;
        }
        .patient-card:hover .avatar-wrap { transform: scale(1.06) rotate(-1deg); }
        .avatar-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .avatar-wrap i { font-size: 1.4rem; color: var(--mint-300); }

        .id-block { min-width: 0; }
        .patient-name {
            font-family: 'Sora', sans-serif;
            font-size: 1.08rem;
            font-weight: 700;
            margin: 0 0 4px;
            display: flex;
            align-items: center;
            gap: 7px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .patient-name i { color: var(--teal-400); font-size: 0.85rem; }

        .patient-meta {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: var(--text-muted);
        }

        .status-pill {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 100px;
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: capitalize;
            white-space: nowrap;
            border: 1px solid transparent;
        }
        .status-pill i { font-size: 0.65rem; }
        .status-approved { background: var(--ok-soft); color: var(--ok); border-color: rgba(78,226,164,0.3); }
        .status-pending  { background: var(--warn-soft); color: var(--warn); border-color: rgba(255,200,97,0.3); }
        .status-rejected,
        .status-denied    { background: var(--danger-soft); color: var(--danger); border-color: rgba(255,107,107,0.3); }
        .status-default   { background: rgba(255,255,255,0.07); color: var(--text-muted); border-color: var(--border-soft); }

        .card-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--border-soft), transparent);
            margin: 14px 0;
        }

        .field-row {
            display: flex;
            align-items: flex-start;
            gap: 11px;
            padding: 7px 0;
        }
        .field-icon {
            width: 30px; height: 30px;
            border-radius: 9px;
            background: rgba(28,171,151,0.12);
            color: var(--mint-300);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem;
            flex-shrink: 0;
            margin-top: 1px;
        }
        .field-text { min-width: 0; }
        .field-label {
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            margin: 0 0 2px;
            font-weight: 700;
        }
        .field-value {
            font-size: 0.9rem;
            color: var(--text-primary);
            margin: 0;
            line-height: 1.4;
            word-break: break-word;
        }
        .field-value.unassigned {
            color: var(--danger);
            font-style: italic;
            font-weight: 600;
        }
        .field-value.unassigned i { margin-right: 5px; }

        .card-actions {
            display: flex;
            gap: 10px;
            margin-top: 18px;
        }

        .action-link {
            flex: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 10px 14px;
            border-radius: 12px;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 700;
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
            border: 1px solid var(--border-soft);
        }
        .action-edit {
            color: var(--mint-300);
            background: rgba(28,171,151,0.10);
        }
        .action-edit:hover {
            background: rgba(28,171,151,0.22);
            border-color: var(--teal-500);
            transform: translateY(-2px);
            box-shadow: 0 10px 22px -10px rgba(28,171,151,0.6);
        }
        .action-delete {
            color: var(--danger);
            background: rgba(255,107,107,0.08);
        }
        .action-delete:hover {
            background: rgba(255,107,107,0.18);
            border-color: rgba(255,107,107,0.5);
            transform: translateY(-2px);
            box-shadow: 0 10px 22px -10px rgba(255,107,107,0.5);
        }
        .action-link i { font-size: 0.8rem; transition: transform 0.25s ease; }
        .action-link:hover i { transform: scale(1.15); }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 70px 20px;
            color: var(--text-muted);
            border: 1px dashed var(--border-soft);
            border-radius: 20px;
            background: var(--surface);
            opacity: 0;
            animation: fadeSlideUp 0.6s ease forwards;
        }
        .empty-state i {
            font-size: 2.4rem;
            color: var(--teal-500);
            margin-bottom: 14px;
            display: block;
        }
        .empty-state h3 {
            font-family: 'Sora', sans-serif;
            color: var(--text-primary);
            margin: 0 0 6px;
        }

        @keyframes fadeSlideDown {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(24px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }

        @media (max-width: 720px) {
            .stats-strip { grid-template-columns: repeat(2, 1fr); }
            .topbar { flex-direction: column; align-items: flex-start; }
        }
    </style>
</head>
<body>
    <div class="shell">

        <div class="topbar">
            <a href="/medIntimate" class="brand-back">
                <i class="fa-solid fa-arrow-left-long"></i> Back to Dashboard
            </a>
        </div>

        <div class="topbar" style="margin-top:-10px;">
            <div class="header-block">
                <div class="eyebrow"><i class="fa-solid fa-heart-pulse"></i> MedIntimate · Patient Registry</div>
                <h1 class="page-title">All Patient Records</h1>
                <p class="page-sub">A complete, real-time overview of every patient currently on file.</p>
            </div>

            <form method="get" action="/medIntimate/patients/new">
                <button type="submit" class="new-patient-btn">
                    <i class="fa-solid fa-user-plus"></i> New Patient
                </button>
            </form>
        </div>

        <% 
            const total = patients.length;
            const approvedCount = patients.filter(p => (p.claimStatus || '').toLowerCase() === 'approved').length;
            const pendingCount  = patients.filter(p => (p.claimStatus || '').toLowerCase() === 'pending').length;
            const unassignedCount = patients.filter(p => !p.assignedStaff).length;
        %>
        <div class="stats-strip">
            <div class="stat-card" style="animation-delay:.05s">
                <div class="stat-icon total"><i class="fa-solid fa-users"></i></div>
                <div>
                    <div class="stat-value"><%= total %></div>
                    <div class="stat-label">Total Patients</div>
                </div>
            </div>
            <div class="stat-card" style="animation-delay:.1s">
                <div class="stat-icon approved"><i class="fa-solid fa-circle-check"></i></div>
                <div>
                    <div class="stat-value"><%= approvedCount %></div>
                    <div class="stat-label">Approved Claims</div>
                </div>
            </div>
            <div class="stat-card" style="animation-delay:.15s">
                <div class="stat-icon pending"><i class="fa-solid fa-hourglass-half"></i></div>
                <div>
                    <div class="stat-value"><%= pendingCount %></div>
                    <div class="stat-label">Pending Review</div>
                </div>
            </div>
            <div class="stat-card" style="animation-delay:.2s">
                <div class="stat-icon unassigned"><i class="fa-solid fa-user-slash"></i></div>
                <div>
                    <div class="stat-value"><%= unassignedCount %></div>
                    <div class="stat-label">Unassigned Staff</div>
                </div>
            </div>
        </div>

        <div class="grid">
            <% if (patients.length === 0) { %>
                <div class="empty-state">
                    <i class="fa-solid fa-folder-open"></i>
                    <h3>No patients found</h3>
                    <p>New patient records will appear here once added.</p>
                </div>
            <% } else { %>
                <% patients.forEach(function(patient, idx) { 
                    const statusRaw = (patient.claimStatus || 'unknown').toLowerCase();
                    let statusClass = 'status-default';
                    let statusIcon = 'fa-circle-question';
                    if (statusRaw === 'approved') { statusClass = 'status-approved'; statusIcon = 'fa-circle-check'; }
                    else if (statusRaw === 'pending') { statusClass = 'status-pending'; statusIcon = 'fa-hourglass-half'; }
                    else if (statusRaw === 'rejected' || statusRaw === 'denied') { statusClass = 'status-rejected'; statusIcon = 'fa-circle-xmark'; }
                    const delay = (idx * 0.06).toFixed(2);
                %>
                <div class="patient-card" style="--delay: <%= delay %>s;">
                    <div class="card-top">
                        <div class="avatar-wrap">
                            <% if (patient.image) { %>
                                <img src="<%= patient.image %>" alt="<%= patient.patientName %>">
                            <% } else { %>
                                <i class="fa-solid fa-user"></i>
                            <% } %>
                        </div>
                        <div class="id-block">
                            <p class="patient-name"><i class="fa-solid fa-user-pen"></i> <%= patient.patientName %></p>
                            <div class="patient-meta">
                                <i class="fa-solid fa-id-card"></i>
                                <span>ID: <%= patient._id.toString().slice(-6).toUpperCase() %></span>
                            </div>
                        </div>
                        <span class="status-pill <%= statusClass %>">
                            <i class="fa-solid <%= statusIcon %>"></i> <%= patient.claimStatus || 'Unknown' %>
                        </span>
                    </div>

                    <div class="card-divider"></div>

                    <div class="field-row">
                        <div class="field-icon"><i class="fa-solid fa-file-waveform"></i></div>
                        <div class="field-text">
                            <p class="field-label">Reason / Medical History</p>
                            <p class="field-value"><%= patient.reason %></p>
                        </div>
                    </div>

                    <div class="field-row">
                        <div class="field-icon"><i class="fa-solid fa-user-doctor"></i></div>
                        <div class="field-text">
                            <p class="field-label">Assigned Staff</p>
                            <% if (patient.assignedStaff) { %>
                                <p class="field-value"><%= patient.assignedStaff.staffName %></p>
                            <% } else { %>
                                <p class="field-value unassigned"><i class="fa-solid fa-triangle-exclamation"></i>No Staff Assigned</p>
                            <% } %>
                        </div>
                    </div>

                    <div class="field-row">
                        <div class="field-icon"><i class="fa-solid fa-calendar-check"></i></div>
                        <div class="field-text">
                            <p class="field-label">Claim Status</p>
                            <p class="field-value"><%= patient.claimStatus %></p>
                        </div>
                    </div>

                    <div class="card-actions">
                        <a href="/medIntimate/patients/<%= patient._id %>/edit" class="action-link action-edit">
                            <i class="fa-solid fa-pen-to-square"></i> Edit
                        </a>
                        <a href="/medIntimate/patients/<%= patient._id %>/delete" class="action-link action-delete"
                           onclick="return confirm('Are you sure you want to delete this patient record?');">
                            <i class="fa-solid fa-trash-can"></i> Delete
                        </a>
                    </div>
                </div>
                <% }); %>
            <% } %>
        </div>
    </div>
</body>
</html>