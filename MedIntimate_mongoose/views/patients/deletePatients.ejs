<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedIntimate | Delete Patient</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --teal-950: #04211f; --teal-900: #06302c; --teal-800: #0a4a43;
            --teal-700: #0f6b60; --teal-600: #15897a; --teal-500: #1cab97;
            --teal-400: #3fc9b4; --mint-300: #8fe9d6;
            --bg-deep: #071a1d;
            --surface: rgba(255,255,255,0.045);
            --surface-strong: rgba(255,255,255,0.08);
            --border-soft: rgba(143,233,214,0.16);
            --text-primary: #eafffa; --text-muted: #9fc7c0;
            --danger: #ff6b6b; --danger-soft: rgba(255,107,107,0.12);
            --warn: #ffc861; --warn-soft: rgba(255,200,97,0.12);
            --ok: #4ee2a4; --ok-soft: rgba(78,226,164,0.12);
            --shadow-glow: 0 0 0 1px rgba(143,233,214,0.08), 0 20px 60px -20px rgba(0,0,0,0.6);
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0; padding: 0; min-height: 100vh;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-primary);
            background-color: var(--bg-deep);
        }

        body {
            background-image:
                linear-gradient(180deg, rgba(4,18,20,0.92) 0%, rgba(4,24,24,0.95) 45%, rgba(2,12,13,0.98) 100%),
                url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed; inset: 0;
            background:
                radial-gradient(900px 500px at 12% -5%, rgba(28,171,151,0.20), transparent 60%),
                radial-gradient(700px 500px at 110% 10%, rgba(63,201,180,0.14), transparent 60%);
            pointer-events: none; z-index: 0;
        }

        .shell {
            position: relative; z-index: 1;
            max-width: 560px;
            margin: 0 auto;
            padding: 38px 28px 80px;
        }

        .topbar {
            display: flex; align-items: center; gap: 18px;
            margin-bottom: 30px;
            opacity: 0; animation: fadeSlideDown 0.6s ease forwards;
        }

        .brand-back {
            display: inline-flex; align-items: center; gap: 10px;
            text-decoration: none; color: var(--text-muted);
            font-weight: 600; font-size: 0.92rem;
            padding: 9px 16px 9px 12px;
            border-radius: 100px;
            border: 1px solid var(--border-soft);
            background: var(--surface);
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
        }
        .brand-back i { transition: transform 0.28s ease; }
        .brand-back:hover {
            color: var(--mint-300); background: var(--surface-strong);
            border-color: var(--teal-500);
            box-shadow: 0 0 0 4px rgba(28,171,151,0.10);
            transform: translateY(-1px);
        }
        .brand-back:hover i { transform: translateX(-3px); }

        .eyebrow {
            display: inline-flex; align-items: center; gap: 8px;
            font-size: 0.72rem; letter-spacing: 0.14em;
            text-transform: uppercase; color: var(--mint-300);
            font-weight: 700; margin-bottom: 10px;
        }

        h1.page-title {
            font-family: 'Sora', sans-serif;
            font-size: clamp(1.5rem, 3vw, 2rem);
            margin: 0 0 6px; font-weight: 800;
            background: linear-gradient(95deg, #ffffff 10%, var(--mint-300) 90%);
            -webkit-background-clip: text; background-clip: text; color: transparent;
        }

        .page-sub { margin: 0; color: var(--text-muted); font-size: 0.9rem; }

        /* Patient Preview Card */
        .patient-preview {
            background: linear-gradient(165deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
            border: 1px solid var(--border-soft);
            border-radius: 20px; padding: 20px;
            display: flex; gap: 16px; align-items: flex-start;
            margin: 24px 0;
            box-shadow: var(--shadow-glow);
            opacity: 0; animation: fadeSlideUp 0.6s ease 0.1s forwards;
        }

        .avatar-wrap {
            width: 60px; height: 60px; border-radius: 16px;
            overflow: hidden; flex-shrink: 0;
            border: 1px solid var(--border-soft);
            background: var(--teal-900);
            display: flex; align-items: center; justify-content: center;
        }
        .avatar-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .avatar-wrap i { font-size: 1.4rem; color: var(--mint-300); }

        .patient-info { min-width: 0; }
        .patient-name {
            font-family: 'Sora', sans-serif; font-size: 1.05rem; font-weight: 700;
            margin: 0 0 5px; display: flex; align-items: center; gap: 7px;
        }
        .patient-name i { color: var(--teal-400); font-size: 0.82rem; }

        .meta-row {
            display: flex; align-items: center; gap: 7px;
            font-size: 0.8rem; color: var(--text-muted); margin-top: 4px;
        }
        .meta-row i { color: var(--teal-400); font-size: 0.75rem; }

        .status-pill {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 5px 11px; border-radius: 100px;
            font-size: 0.7rem; font-weight: 700;
            margin-top: 8px; border: 1px solid transparent;
        }
        .status-approved { background: var(--ok-soft); color: var(--ok); border-color: rgba(78,226,164,0.3); }
        .status-pending  { background: var(--warn-soft); color: var(--warn); border-color: rgba(255,200,97,0.3); }
        .status-rejected { background: var(--danger-soft); color: var(--danger); border-color: rgba(255,107,107,0.3); }

        /* Warning Banner */
        .warn-banner {
            background: var(--danger-soft);
            border: 1px solid rgba(255,107,107,0.28);
            border-radius: 14px; padding: 14px 18px;
            display: flex; gap: 12px; align-items: flex-start;
            color: #ff8a8a; font-size: 0.87rem; font-weight: 600;
            opacity: 0; animation: fadeSlideUp 0.6s ease 0.2s forwards;
        }
        .warn-banner i { font-size: 1.05rem; margin-top: 1px; flex-shrink: 0; }

        /* Form */
        .del-form {
            opacity: 0; animation: fadeSlideUp 0.6s ease 0.3s forwards;
        }

        .divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--border-soft), transparent);
            margin: 22px 0;
        }

        .field-label {
            display: block;
            font-size: 0.7rem; text-transform: uppercase;
            letter-spacing: 0.07em; color: var(--text-muted);
            font-weight: 700; margin: 0 0 8px;
        }

        .del-input {
            width: 100%;
            background: rgba(255,255,255,0.06);
            border: 1px solid var(--border-soft);
            border-radius: 12px; padding: 13px 16px;
            color: var(--text-primary);
            font-size: 0.95rem; font-family: 'Plus Jakarta Sans', sans-serif;
            outline: none;
            transition: border-color 0.25s, box-shadow 0.25s;
        }
        .del-input::placeholder { color: rgba(143,233,214,0.3); }
        .del-input:focus {
            border-color: var(--teal-500);
            box-shadow: 0 0 0 3px rgba(28,171,151,0.18);
        }

        .input-hint {
            font-size: 0.77rem; color: var(--text-muted);
            margin: 7px 0 0; display: flex; gap: 6px; align-items: center;
        }
        .input-hint i { color: var(--teal-400); font-size: 0.8rem; }

        /* Buttons */
        .btn-row { display: flex; gap: 12px; margin-top: 24px; }

        .btn-cancel {
            flex: 1; padding: 13px 18px;
            border-radius: 13px;
            border: 1px solid var(--border-soft);
            background: var(--surface);
            color: var(--text-muted);
            font-weight: 700; font-size: 0.9rem;
            cursor: pointer; font-family: 'Plus Jakarta Sans', sans-serif;
            text-decoration: none;
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            transition: all 0.25s;
        }
        .btn-cancel:hover {
            background: var(--surface-strong);
            color: var(--text-primary);
            border-color: var(--teal-500);
        }

        .btn-delete {
            flex: 1; padding: 13px 18px;
            border-radius: 13px; border: none;
            background: linear-gradient(135deg, #ff6b6b, #c0392b);
            color: #fff;
            font-weight: 700; font-size: 0.9rem;
            cursor: pointer; font-family: 'Plus Jakarta Sans', sans-serif;
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
            box-shadow: 0 8px 24px -8px rgba(255,80,80,0.5);
        }
        .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 14px 32px -8px rgba(255,80,80,0.65);
        }
        .btn-delete:active { transform: scale(0.97); }

        @keyframes fadeSlideDown {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
    </style>
</head>
<body>
    <div class="shell">

        <div class="topbar">
            <a href="/medIntimate/patients" class="brand-back">
                <i class="fa-solid fa-arrow-left-long"></i> Back to Patients
            </a>
        </div>

        <div class="eyebrow"><i class="fa-solid fa-trash-can"></i> MedIntimate · Delete Record</div>
        <h1 class="page-title">Delete patient record?</h1>
        <p class="page-sub">This action is permanent and cannot be undone.</p>

        <!-- Patient Preview -->
        <div class="patient-preview">
            <div class="avatar-wrap">
                <% if (patient.image) { %>
                    <img src="<%= patient.image %>" alt="<%= patient.patientName %>">
                <% } else { %>
                    <i class="fa-solid fa-user"></i>
                <% } %>
            </div>
            <div class="patient-info">
                <p class="patient-name">
                    <i class="fa-solid fa-user-pen"></i> <%= patient.patientName %>
                </p>
                <div class="meta-row">
                    <i class="fa-solid fa-id-card"></i>
                    <span>ID: <%= patient._id.toString().slice(-6).toUpperCase() %></span>
                </div>
                <div class="meta-row">
                    <i class="fa-solid fa-file-waveform"></i>
                    <span><%= patient.reason %></span>
                </div>
                <% 
                    const s = (patient.claimStatus || '').toLowerCase();
                    let sc = 'status-pending', si = 'fa-hourglass-half';
                    if (s === 'approved') { sc = 'status-approved'; si = 'fa-circle-check'; }
                    else if (s === 'rejected' || s === 'denied') { sc = 'status-rejected'; si = 'fa-circle-xmark'; }
                %>
                <span class="status-pill <%= sc %>">
                    <i class="fa-solid <%= si %>"></i> <%= patient.claimStatus %>
                </span>
            </div>
        </div>

        <!-- Warning -->
        <div class="warn-banner">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>All associated medical history, claim records, and staff assignments will be permanently deleted.</span>
        </div>

        <!-- Form -->
        <form method="POST" action="/medIntimate/patients/<%= patient._id %>?_method=DELETE" class="del-form">
            <div class="divider"></div>

            <label for="del-pass" class="field-label">
                <i class="fa-solid fa-shield-halved" style="margin-right:5px"></i>
                Type patient's reason to confirm
            </label>
            <input
                type="text"
                id="del-pass"
                name="patientDeletePassword"
                class="del-input"
                placeholder="e.g. Diabetes, Fracture"
                autocomplete="off"
                required
            >
            <p class="input-hint">
                <i class="fa-solid fa-circle-info"></i>
                Must match exactly as entered during registration
            </p>

            <div class="btn-row">
                <a href="/medIntimate/patients" class="btn-cancel">
                    <i class="fa-solid fa-arrow-left"></i> Cancel
                </a>
                <button type="submit" class="btn-delete">
                    <i class="fa-solid fa-trash-can"></i> Confirm delete
                </button>
            </div>
        </form>

    </div>
</body>
</html>