<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Patient | MedIntimate</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Sora:wght@600;700;800&display=swap" rel="stylesheet">

    <style>
        :root {
            --teal-950: #04211f;
            --teal-900: #06302c;
            --teal-800: #0a4a43;
            --teal-700: #0f6b60;
            --teal-600: #15897a;
            --teal-500: #1cab97;
            --teal-400: #3fc9b4;
            --mint-300: #8fe9d6;
            --bg-deep: #071a1d;
            --surface: rgba(255, 255, 255, 0.045);
            --surface-strong: rgba(255, 255, 255, 0.08);
            --border-soft: rgba(143, 233, 214, 0.16);
            --text-primary: #eafffa;
            --text-muted: #9fc7c0;
            --danger: #ff6b6b;
            --shadow-glow: 0 0 0 1px rgba(143,233,214,0.08), 0 20px 60px -20px rgba(0,0,0,0.6);
        }

        * { box-sizing: border-box; }

        html, body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: var(--text-primary);
            background-color: var(--bg-deep);
        }

        body {
            position: relative;
            background-image:
                linear-gradient(180deg, rgba(4,18,20,0.92) 0%, rgba(4,24,24,0.95) 45%, rgba(2,12,13,0.98) 100%),
                url('https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=2000&auto=format&fit=crop');
            background-size: cover;
            background-position: center top;
            background-attachment: fixed;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed;
            inset: 0;
            background:
                radial-gradient(900px 500px at 12% -5%, rgba(28,171,151,0.20), transparent 60%),
                radial-gradient(700px 500px at 110% 10%, rgba(63,201,180,0.14), transparent 60%);
            pointer-events: none;
            z-index: 0;
        }

        .shell {
            position: relative;
            z-index: 1;
            max-width: 720px;
            margin: 0 auto;
            padding: 48px 24px 80px;
        }

        .topbar {
            margin-bottom: 26px;
            opacity: 0;
            animation: fadeSlideDown 0.6s ease forwards;
        }

        .brand-back {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 600;
            font-size: 0.92rem;
            padding: 9px 16px 9px 12px;
            border-radius: 100px;
            border: 1px solid var(--border-soft);
            background: var(--surface);
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
        }
        .brand-back i { transition: transform 0.28s ease; }
        .brand-back:hover {
            color: var(--mint-300);
            background: var(--surface-strong);
            border-color: var(--teal-500);
            box-shadow: 0 0 0 4px rgba(28,171,151,0.10);
            transform: translateY(-1px);
        }
        .brand-back:hover i { transform: translateX(-3px); }

        .header-block {
            margin-bottom: 28px;
            opacity: 0;
            animation: fadeSlideUp 0.7s ease 0.05s forwards;
        }
        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 0.72rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--mint-300);
            font-weight: 700;
            margin-bottom: 10px;
        }
        h1.page-title {
            font-family: 'Sora', sans-serif;
            font-size: clamp(1.6rem, 3vw, 2.2rem);
            margin: 0 0 6px;
            font-weight: 800;
            letter-spacing: -0.01em;
            background: linear-gradient(95deg, #ffffff 10%, var(--mint-300) 90%);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }
        .page-sub { margin: 0; color: var(--text-muted); font-size: 0.95rem; }

        /* ===== Form card ===== */
        .form-card {
            position: relative;
            background: linear-gradient(165deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
            border: 1px solid var(--border-soft);
            border-radius: 22px;
            padding: 32px;
            backdrop-filter: blur(6px);
            box-shadow: var(--shadow-glow);
            opacity: 0;
            transform: translateY(22px);
            animation: cardIn 0.6s cubic-bezier(.16,1,.3,1) 0.1s forwards;
        }

        form { display: flex; flex-direction: column; gap: 20px; }

        .field-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            opacity: 0;
            transform: translateY(14px);
            animation: fadeSlideUp 0.5s ease forwards;
        }

        .field-group label {
            display: flex;
            align-items: center;
            gap: 9px;
            font-size: 0.82rem;
            font-weight: 700;
            color: var(--mint-300);
            letter-spacing: 0.02em;
        }
        .field-group label i {
            width: 28px; height: 28px;
            border-radius: 9px;
            background: rgba(28,171,151,0.14);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.78rem;
            color: var(--mint-300);
            flex-shrink: 0;
        }

        .input-wrap { position: relative; }

        input, select {
            width: 100%;
            padding: 13px 16px;
            font-size: 0.95rem;
            font-family: inherit;
            color: var(--text-primary);
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border-soft);
            border-radius: 12px;
            outline: none;
            transition: all 0.28s cubic-bezier(.4,0,.2,1);
            appearance: none;
        }
        input::placeholder { color: rgba(159, 199, 192, 0.55); }

        select {
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='9' viewBox='0 0 14 9'><path d='M1 1l6 6 6-6' stroke='%238fe9d6' stroke-width='1.6' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>");
            background-repeat: no-repeat;
            background-position: right 16px center;
            padding-right: 40px;
            cursor: pointer;
        }
        select option { background: var(--teal-950); color: var(--text-primary); }

        input:hover, select:hover {
            border-color: rgba(143,233,214,0.35);
            background: rgba(255,255,255,0.06);
        }

        input:focus, select:focus {
            border-color: var(--teal-500);
            background: rgba(255,255,255,0.07);
            box-shadow: 0 0 0 4px rgba(28,171,151,0.16);
        }

        .hint {
            font-size: 0.74rem;
            color: var(--text-muted);
            margin: 0;
        }

        .submit-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            padding: 15px 22px;
            border-radius: 14px;
            border: none;
            background: linear-gradient(135deg, var(--teal-500), var(--teal-700));
            color: #06231f;
            font-weight: 800;
            font-size: 0.98rem;
            cursor: pointer;
            margin-top: 6px;
            box-shadow: 0 10px 30px -8px rgba(28,171,151,0.55);
            transition: all 0.3s cubic-bezier(.4,0,.2,1);
            position: relative;
            overflow: hidden;
            opacity: 0;
            transform: translateY(14px);
            animation: fadeSlideUp 0.5s ease 0.55s forwards;
        }
        .submit-btn::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent, rgba(255,255,255,0.35), transparent);
            transform: translateX(-120%);
            transition: transform 0.6s ease;
        }
        .submit-btn:hover {
            transform: translateY(-2px) scale(1.01);
            box-shadow: 0 16px 38px -8px rgba(28,171,151,0.7);
        }
        .submit-btn:hover::before { transform: translateX(120%); }
        .submit-btn:active { transform: translateY(0) scale(0.98); }

        @keyframes fadeSlideDown {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(16px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(24px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }

        @media (max-width: 540px) {
            .shell { padding: 32px 16px 60px; }
            .form-card { padding: 22px; }
        }
    </style>
</head>
<body>
    <div class="shell">

        <div class="topbar">
            <a href="/medIntimate/patients" class="brand-back">
                <i class="fa-solid fa-arrow-left-long"></i> Back to Patients
            </a>
        </div>

        <div class="header-block">
            <div class="eyebrow"><i class="fa-solid fa-heart-pulse"></i> MedIntimate · Patient Registry</div>
            <h1 class="page-title">Add New Patient</h1>
            <p class="page-sub">Fill in the details below to register a new patient record.</p>
        </div>

        <div class="form-card">
            <form method="POST" action="/medIntimate/patients">

                <div class="field-group" style="animation-delay:.05s">
                    <label for="name"><i class="fa-solid fa-user"></i> Patient Name</label>
                    <div class="input-wrap">
                        <input type="text" id="name" name="patientName" placeholder="Enter patient name" required>
                    </div>
                </div>

                <div class="field-group" style="animation-delay:.1s">
                    <label for="reason"><i class="fa-solid fa-file-waveform"></i> Reason / Disease</label>
                    <div class="input-wrap">
                        <input type="text" id="reason" name="reason" placeholder="Enter patient disease / reason" required>
                    </div>
                </div>

                <div class="field-group" style="animation-delay:.15s">
                    <label for="status"><i class="fa-solid fa-calendar-check"></i> Claim Status</label>
                    <div class="input-wrap">
                        <select id="status" name="claimStatus">
                            <option value="Intimation Sent">Intimation Sent</option>
                            <option value="Under Review">Under Review</option>
                            <option value="Approved">Approved</option>
                        </select>
                    </div>
                </div>

                <div class="field-group" style="animation-delay:.2s">
                    <label for="staff"><i class="fa-solid fa-user-doctor"></i> Assigned Staff (Doctor)</label>
                    <div class="input-wrap">
                        <select id="staff" name="assignedStaff">
                            <option value="">-- Select Doctor --</option>
                            <% for(let staff of staffs) { %>
                                <option value="<%= staff._id %>">
                                    <%= staff.staffName %> (<%= staff.designation %>)
                                </option>
                            <% } %>
                        </select>
                    </div>
                </div>

                <div class="field-group" style="animation-delay:.25s">
                    <label for="img"><i class="fa-solid fa-image"></i> Patient Image URL</label>
                    <div class="input-wrap">
                        <input type="url" id="img" name="image" placeholder="https://example.com/photo.jpg">
                    </div>
                    <p class="hint">Optional — a default avatar will be shown if left blank.</p>
                </div>

                <button type="submit" class="submit-btn">
                    <i class="fa-solid fa-user-plus"></i> Add Patient
                </button>
            </form>
        </div>
    </div>
</body>
</html>